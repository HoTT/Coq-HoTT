    {
      "_type": "sentence",
      "contents": "Definition tail_cons {X : Type} (u : nat -> X) {x : X} : seq_tail (seq_cons x u) == u\n  := fun _ => idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Equivalence relations on sequences.  *)\n\n(** For every [n : nat], we define a relation between two sequences that holds if and only if their first [n] terms are equal. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition seq_agree_lt {X : Type} (n : nat) (s t : nat -> X) : Type\n  := forall (m : nat), m < n -> s m = t m.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** [seq_agree_lt] has an equivalent inductive definition. We don't use this equivalence, but include it in case it is useful in future work. *)\n"
    },
