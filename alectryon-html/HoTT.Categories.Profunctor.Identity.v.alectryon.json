      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
