      "contents": "(** * Identity profunctor *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Profunctor.Core HomFunctor.",
