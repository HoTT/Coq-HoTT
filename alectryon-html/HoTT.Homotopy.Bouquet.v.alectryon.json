    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Univalence}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** An S-indexed wedge of circles a.k.a a bouquet can be defined as the suspension of the pointification of S. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition Bouquet (S : Type) : pType := psusp (pointify S).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance isconnected_bouquet (S : Type)\n    : IsConnected 0 (Bouquet S).",
