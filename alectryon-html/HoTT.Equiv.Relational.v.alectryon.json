    {
      "_type": "text",
      "contents": "\n\n(** * Relational equivalences *)\n\n(** This definition is due to Peter LeFanu Lumsdaine on the HoTT mailing list.  This definition gives more judgmental properties, though has the downside of jumping universe levels. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record RelEquiv A B :=\n  { equiv_rel : A -> B -> Type;\n    relequiv_contr_f :: forall a, Contr { b : B & equiv_rel a b };\n    relequiv_contr_g :: forall b, Contr { a : A & equiv_rel a b } }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments equiv_rel {A B} _ _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition issig_relequiv {A B}\n  : { equiv_rel : A -> B -> Type\n    | { f : forall a, Contr { b : B & equiv_rel a b }\n      | forall b, Contr { a : A & equiv_rel a b } } }\n      <~> RelEquiv A B.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "{equiv_rel0 : A -> B -> Type &\n{_ : forall a : A, Contr {b : B & equiv_rel0 a b} &\nforall b : B, Contr {a : A & equiv_rel0 a b}}} <~> \nRelEquiv A B",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
              "body": null,
              "type": "Type"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "{equiv_rel0 : A -> B -> Type &\n{_ : forall a : A, Contr {b : B & equiv_rel0 a b} &\nforall b : B, Contr {a : A & equiv_rel0 a b}}} <~> \nRelEquiv A B",
          "hypotheses": [
