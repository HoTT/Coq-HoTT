    {
      "_type": "sentence",
      "contents": "Definition RelIsEquiv {A B} (f : A -> B)\n  := { r : RelEquiv A B | forall x, (center { b : B & equiv_rel r x b }).1 = f x }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** TODO: Prove [ishprop_relisequiv `{Funext} {A B} f : IsHProp (@RelIsEquiv A B f)] *)\n\n(** * Judgmental property *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse_relequiv {A B} (e : RelEquiv A B) : RelEquiv B A\n  := {| equiv_rel a b := equiv_rel e b a |}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition reinv_V {A B} (e : RelEquiv A B)\n  : inverse_relequiv (inverse_relequiv e) = e\n  := 1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** TODO: Is there a definition of this that makes [inverse_relequiv (relequiv_idmap A)] be [relequiv_idmap A], judgmentally? *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition relequiv_idmap A : RelEquiv A A\n  := {| equiv_rel a b := a = b |}.",
      "messages": [],
      "goals": []
