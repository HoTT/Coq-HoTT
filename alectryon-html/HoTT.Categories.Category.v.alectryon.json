[
  [
    {
      "_type": "sentence",
      "contents": "(** * Categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** We collect here all of the files about categories. *)\n(** Since there are only notations in [Category.Notations], we can just export those. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export Category.Notations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Opposite precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Morphisms in precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Morphisms.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Classification of path space *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Universal objects *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Objects.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Product precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Prod.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Dependent product precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Pi.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** \u2211-precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Sigma.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Strict categories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Strict.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Coproduct precategories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Sum.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Categories (univalent or saturated) *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Univalent.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Warnings \"-notation-overridden\".",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Morphisms.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Objects.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Prod.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Pi.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** We use the [Sigma] folder only to allow us to split up the various files and group conceptually similar lemmas, but not for namespacing.  So we include the main file in it. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Sigma.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Strict.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Sum.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include Category.Univalent.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** We don't want to make UTF-8 notations the default, so we don't export them. *)\n\n(** ** Subcategories *)\n(** For the subfolders, we need to re-create the module structure.  Alas, namespacing in Coq is kind-of broken (see, e.g., https://coq.inria.fr/bugs/show_bug.cgi?id=3676), so we don't get the ability to rename subfolders by [Including] into other modules. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Subcategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]