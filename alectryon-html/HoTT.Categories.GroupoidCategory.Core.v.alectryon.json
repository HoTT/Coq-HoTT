[
  [
    {
      "_type": "sentence",
      "contents": "(** * Groupoids *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Morphisms Category.Strict.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Trunc PathGroupoids Basics.Tactics.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** A groupoid is a precategory where every morphism is an isomorphism.  Since 1-types are 1-groupoids, we can construct the category corresponding to the 1-groupoid of a 1-type. *)\n\n(** ** Definition of what it means to be a groupoid *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Class IsGroupoid (C : PreCategory)\n  := isgroupoid : forall s d (m : morphism C s d),\n                    IsIsomorphism m.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance trunc_isgroupoid `{Funext} C : IsHProp (IsGroupoid C)\n  := istrunc_forall.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We don't want access to all of the internals of a groupoid category at top level. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module GroupoidCategoryInternals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section groupoid_category.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable X : Type.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsTrunc 1 X}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation morphism := (@paths X).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose s d d' (m : morphism d d') (m' : morphism s d)\n    : morphism s d'\n      := transitivity m' m.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition identity x : morphism x x\n      := reflexivity _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments compose [s d d'] m m' / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments identity x / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End groupoid_category.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End GroupoidCategoryInternals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Categorification of the groupoid of a 1-type *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition groupoid_category X `{IsTrunc 1 X} : PreCategory.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsTrunc0"
              ],
              "body": null,
              "type": "IsTrunc 1 X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsTrunc0"
              ],
              "body": null,
              "type": "IsTrunc 1 X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (@Build_PreCategory X\n                             (@paths X)\n                             (@GroupoidCategoryInternals.identity X)\n                             (@GroupoidCategoryInternals.compose X)\n                             _\n                             _\n                             _\n                             _);\n  simpl; intros; path_induction; reflexivity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments groupoid_category X {_}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isgroupoid_groupoid_category X `{IsTrunc 1 X}\n: IsGroupoid (groupoid_category X).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsGroupoid (groupoid_category X)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsTrunc0"
              ],
              "body": null,
              "type": "IsTrunc 1 X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsGroupoid (groupoid_category X)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsTrunc0"
              ],
              "body": null,
              "type": "IsTrunc 1 X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "intros s d m; simpl in *.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsIsomorphism m",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsTrunc0"
              ],
              "body": null,
              "type": "IsTrunc 1 X"
            },
            {
              "_type": "hypothesis",
              "names": [
                "s",
                "d"
              ],
              "body": null,
              "type": "X"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "s = d"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "exact (Build_IsIsomorphism\n           (groupoid_category X)\n           s d\n           m m^%path\n           (concat_pV m)\n           (concat_Vp m)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** 0-types give rise to strict (groupoid) categories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Lemma isstrict_groupoid_category X `{IsHSet X}\n: IsStrictCategory (groupoid_category X).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
