    {
      "_type": "text",
      "contents": "\n\n(** ** Coherent H-space structures *)\n\n(** An H-space is coherent when the left and right identities agree at the base point. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Class IsCoherent (X : pType) `{IsHSpace X} :=\n  iscoherent : left_identity pt = right_identity pt.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record IsCohHSpace (A : pType) := {\n    ishspace_cohhspace :: IsHSpace A;\n    iscoherent_cohhspace :: IsCoherent A;\n  }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition issig_iscohhspace (A : pType)\n  : { hspace_op : SgOp A\n    & { hspace_left_identity : LeftIdentity hspace_op pt\n    & { hspace_right_identity : RightIdentity hspace_op pt\n    & hspace_left_identity pt = hspace_right_identity pt } } }\n      <~> IsCohHSpace A\n  := ltac:(make_equiv).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** A type equivalent to a coherent H-space is a coherent H-space. *)\n"
    },
    {
