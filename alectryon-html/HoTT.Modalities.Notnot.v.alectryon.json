        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall (A : Type) (B : (fun X : Type => ~~ X) A -> Type)\n(f : forall a : A, (fun X : Type => ~~ X) (B (not_not_unit a))) \n(a : A),\n((fun (A0 : Type) (B0 : ~~ A0 -> Type)\n    (f0 : forall a0 : A0, ~~ B0 (not_not_unit a0)) \n    (z : ~~ A0) =>\n  (fun nBz : ~ B0 z =>\n   z\n     ((fun a0 : A0 =>\n       f0 a0\n         (transport (fun x : ~~ A0 => ~ B0 x)\n            (path_ishprop z (not_not_unit a0)) nBz))\n      :\n      ~ A0))\n  :\n  ~~ B0 z)\n :\n forall (A0 : Type) (B0 : (fun X : Type => ~~ X) A0 -> Type),\n (forall a0 : A0, (fun X : Type => ~~ X) (B0 (not_not_unit a0))) ->\n forall z : (fun X : Type => ~~ X) A0, (fun X : Type => ~~ X) (B0 z)) A B f\n  (not_not_unit a) =\nf a",
