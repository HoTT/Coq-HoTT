      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_unit_coind `{Funext} (A : Type)\n  : Unit <~> (A -> Unit)\n  := Build_Equiv _ _ (@unit_coind A) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Truncation *)\n\n(* The Unit type is contractible *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance contr_unit : Contr Unit | 0 := Build_Contr _ tt (fun t : Unit => match t with tt => 1 end).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Equivalences *)\n\n(** A contractible type is equivalent to [Unit]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_contr_unit `{Contr A} : A <~> Unit\n  := equiv_contr_contr.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(* Conversely, a type equivalent to [Unit] is contractible. We don't make this an instance because Coq would have to guess the equivalence.  And when it has a map in mind, it would try to use [isequiv_contr_contr], which would cause a cycle. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition contr_equiv_unit (A : Type) (f : A <~> Unit) : Contr A\n  := contr_equiv' Unit f^-1%equiv.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The constant map to [Unit].  We define this so we can get rid of an unneeded universe variable that Coq generates when [const tt] is used in a context that doesn't have [Universe Minimization ToSet] as this file does. If we ever set that globally, then we could get rid of this and remove some imports of this file. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition const_tt (A : Type) := @const A Unit tt.",
      "messages": [],
      "goals": []
    },
