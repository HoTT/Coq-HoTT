    {
      "_type": "sentence",
      "contents": "(** * Theorems about the unit type *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Overture Basics.Equivalences.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope path_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Universe Minimization ToSet.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable Variables A.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Eta conversion *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition eta_unit (z : Unit) : tt = z\n  := match z with tt => 1 end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Paths *)\n\n(* This is all kind of ridiculous, but it fits the pattern. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition path_unit_uncurried (z z' : Unit) : Unit -> z = z'\n  := fun _ => match z, z' with tt, tt => 1 end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition path_unit (z z' : Unit) : z = z'\n  := path_unit_uncurried z z' tt.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition eta_path_unit {z z' : Unit} (p : z = z') :\n  path_unit z z' = p.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "path_unit z z' = p",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z",
                "z'"
              ],
              "body": null,
              "type": "Unit"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "z = z'"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "path_unit z z' = p",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z",
                "z'"
              ],
              "body": null,
              "type": "Unit"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "z = z'"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "destruct p.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "path_unit z z = 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z"
              ],
              "body": null,
              "type": "Unit"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": " "
    },
    {
      "_type": "sentence",
      "contents": "destruct z.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "path_unit tt tt = 1",
          "hypotheses": []
        }
      ]
    },
    {
      "_type": "text",
      "contents": " "
    },
    {
      "_type": "sentence",
      "contents": "reflexivity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isequiv_path_unit (z z' : Unit) : IsEquiv (path_unit_uncurried z z') | 0.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (path_unit_uncurried z z')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z",
                "z'"
              ],
              "body": null,
              "type": "Unit"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (path_unit_uncurried z z')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z",
                "z'"
              ],
              "body": null,
              "type": "Unit"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (Build_IsEquiv _ _ (path_unit_uncurried z z') (fun _ => tt)\n    (fun p:z=z' =>\n      match p in (_ = z') return (path_unit_uncurried z z' tt = p) with\n        | idpath => match z as z return (path_unit_uncurried z z tt = 1) with\n                    | tt => 1\n                  end\n      end)\n    (fun x => match x with tt => 1 end) _).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall x : Unit,\nmatch\n  path_unit_uncurried z z' x as p in (_ = z'0)\n  return (path_unit_uncurried z z'0 tt = p)\nwith\n| 1 =>\n    match z as z0 return (path_unit_uncurried z0 z0 tt = 1) with\n    | tt => 1\n    end\nend =\nap (path_unit_uncurried z z')\n  match x as x0 return (tt = x0) with\n  | tt => 1\n  end",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "z",
                "z'"
              ],
              "body": null,
              "type": "Unit"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "intros []; destruct z, z'; reflexivity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_path_unit (z z' : Unit) : Unit <~> (z = z')\n  := Build_Equiv _ _ (path_unit_uncurried z z') _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Transport *)\n\n(** Is a special case of transporting in a constant fibration. *)\n\n(** ** Universal mapping properties *)\n\n(* The positive universal property *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments Unit_ind [A] a u : rename.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isequiv_unit_ind `{Funext} (A : Unit -> Type)\n: IsEquiv (@Unit_ind A) | 0\n  := isequiv_adjointify _\n  (fun f : forall u:Unit, A u => f tt)\n  (fun f : forall u:Unit, A u => path_forall (@Unit_ind A (f tt)) f\n                                             (fun x => match x with tt => 1 end))\n  (fun _ => 1).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isequiv_unit_rec `{Funext} (A : Type)\n: IsEquiv (@Unit_ind (fun _ => A)) | 0\n  := isequiv_unit_ind (fun _ => A).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "#[local]\nHint Extern 4 => progress (cbv beta iota) : typeclass_instances.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_unit_rec `{Funext} (A : Type)\n  : A <~> (Unit -> A)\n  := (Build_Equiv _ _ (@Unit_ind (fun _ => A)) _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(* For various reasons, it is typically more convenient to define functions out of the unit as constant maps, rather than [Unit_ind]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation unit_name x := (fun (_ : Unit) => x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isequiv_unit_name@{i j} `{Funext} (A : Type@{i})\n: @IsEquiv@{i j} _ (Unit -> _) (fun (a:A) => unit_name a).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
