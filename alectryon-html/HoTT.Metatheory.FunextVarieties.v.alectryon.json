              "type": "forall x : A, P x"
            },
            {
              "_type": "hypothesis",
              "names": [
                "h"
              ],
              "body": null,
              "type": "forall x : A, f x = g x"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
