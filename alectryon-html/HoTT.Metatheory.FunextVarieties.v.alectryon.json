              ],
              "body": null,
              "type": "forall (A0 : Type) (P : A0 -> Type),\n(forall x : A0, Contr (P x)) -> Contr (forall x : A0, P x)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
