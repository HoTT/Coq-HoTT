            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "forall x : A, B x"
            },
            {
              "_type": "hypothesis",
              "names": [
                "idhtpy"
              ],
              "body": "fun x : A => 1",
              "type": "f == f"
            },
            {
              "_type": "hypothesis",
              "names": [
                "g"
              ],
              "body": null,
              "type": "forall x : A, B x"
            },
            {
              "_type": "hypothesis",
              "names": [
                "h"
              ],
              "body": null,
              "type": "f == g"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    (* The trick is to show that the type [{g : forall x, B x & f == g }] is a retract of [forall x, {y : B x & f x = y}], which is contractible due to J and weak funext.  Here are the retraction and its section. *)\n    "
    },
    {
      "_type": "sentence",
      "contents": "pose (r := fun k => exist (fun g => f == g)\n      (fun x => (k x).1) (fun x => (k x).2)).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(f; idhtpy) = (g; h)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "wf"
              ],
              "body": null,
              "type": "forall (A0 : Type) (P : A0 -> Type),\n(forall x : A0, Contr (P x)) -> Contr (forall x : A0, P x)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
              "body": null,
              "type": "A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "forall x : A, B x"
            },
            {
              "_type": "hypothesis",
              "names": [
                "idhtpy"
              ],
              "body": "fun x : A => 1",
              "type": "f == f"
            },
            {
              "_type": "hypothesis",
              "names": [
                "g"
              ],
              "body": null,
              "type": "forall x : A, B x"
            },
            {
              "_type": "hypothesis",
              "names": [
