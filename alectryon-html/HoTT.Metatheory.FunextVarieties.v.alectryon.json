            },
            {
              "_type": "hypothesis",
              "names": [
                "r"
              ],
              "body": "fun k : forall x : A, {x0 : _ & f x = x0} =>\n(fun x : A => (k x).1; fun x : A => (k x).2)",
              "type": "(forall x : A, {x0 : _ & f x = x0}) -> {g0 : forall x : A, B x & f == g0}"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "pose (s := fun (g : forall x, B x) (h : f == g) x => (g x ; h x)).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(f; idhtpy) = (g; h)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "wf"
              ],
              "body": null,
              "type": "forall (A0 : Type) (P : A0 -> Type),\n(forall x : A0, Contr (P x)) -> Contr (forall x : A0, P x)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
              "body": null,
              "type": "A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
