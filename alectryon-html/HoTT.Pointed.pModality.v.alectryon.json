    {
      "_type": "text",
      "contents": "\n\n(** * Modalities, reflective subuniverses and pointed types *)\n\n(** So far, everything is about general reflective subuniverses, but in the future results about modalities can be placed here as well. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance ispointed_O `{O : ReflectiveSubuniverse} (X : Type)\n  `{IsPointed X} : IsPointed (O X) := to O _ (point X).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pto (O : ReflectiveSubuniverse@{u}) (X : pType@{u})\n  : X ->* [O X, _]\n  := Build_pMap (to O X) idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** If [A] is already [O]-local, then Coq knows that [pto] is an equivalence, so we can simply define: *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pequiv_pto `{O : ReflectiveSubuniverse} {X : pType} `{In O X}\n  : X <~>* [O X, _] := Build_pEquiv (pto O X) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Applying [O_rec] to a pointed map yields a pointed map. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pO_rec `{O : ReflectiveSubuniverse} {X Y : pType}\n  `{In O Y} (f : X ->* Y) : [O X, _] ->* Y\n  := Build_pMap (O_rec f) (O_rec_beta _ _ @ point_eq f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pO_rec_beta `{O : ReflectiveSubuniverse} {X Y : pType}\n  `{In O Y} (f : X ->* Y)\n  : pO_rec f o* pto O X ==* f.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "pO_rec f o* pto O X ==* f",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "O"
              ],
              "body": null,
              "type": "ReflectiveSubuniverse"
            },
            {
              "_type": "hypothesis",
              "names": [
