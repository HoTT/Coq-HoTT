    {
      "_type": "sentence",
      "contents": "(** * Grothendieck Construction of a functor to Cat *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core.",
      "messages": [],
