      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** There is a category Fun(C, D) of functors from [C] to [D]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_category : PreCategory\n    := @Build_PreCategory (Functor C D)\n                          (@NaturalTransformation C D)\n                          (@identity C D)\n                          (@compose C D)\n                          (@associativity _ C D)\n                          (@left_identity _ C D)\n                          (@right_identity _ C D)\n                          _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End functor_category.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"C -> D\" := (functor_category C D) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** [C \u2192 D] is a strict category if [D] is *)\n"
    },
