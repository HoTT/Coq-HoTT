              ],
              "body": null,
              "type": "nat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "induction n; simpl; trivial.",
      "messages": [],
