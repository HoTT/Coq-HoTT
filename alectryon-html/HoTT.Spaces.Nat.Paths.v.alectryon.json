      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export Basics.Nat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export HoTT.Universes.DProp.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** * Characterization of the path types of [nat] *)\n\n(** We characterize the path types of [nat].  We put this in its own file because it uses [DProp], which has a lot of dependencies. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Universe Minimization ToSet.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Close Scope trunc_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope nat_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint code_nat (m n : nat) {struct m} : DHProp@{Set} :=\n  match m, n with\n  | 0, 0 => True\n  | m'.+1, n'.+1 => code_nat m' n'\n  | _, _ => False\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"=n\" := code_nat : nat_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint idcode_nat {n} : (n =n n) :=\n  match n as n return (n =n n) with\n  | 0 => tt\n  | S n' => @idcode_nat n'\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint path_nat {n m} : (n =n m) -> (n = m) :=\n  match m as m, n as n return (n =n m) -> (n = m) with\n  | 0, 0 => fun _ => idpath\n  | m'.+1, n'.+1 => fun H : (n' =n m') => ap S (path_nat H)\n  | _, _ => fun H => match H with end\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isequiv_path_nat {n m} : IsEquiv (@path_nat n m).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv path_nat",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
                "m"
              ],
              "body": null,
              "type": "nat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv path_nat",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
                "m"
              ],
              "body": null,
              "type": "nat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (isequiv_adjointify\n            (@path_nat n m)\n            (fun H => transport (fun m' => (n =n m')) H idcode_nat)\n            _ _).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(fun x : n = m => path_nat (transport (fun m' : nat => n =n m') x idcode_nat)) ==\nidmap",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
                "m"
              ],
              "body": null,
              "type": "nat"
            }
          ]
        },
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(fun x : n =n m =>\n transport (fun m' : nat => n =n m') (path_nat x) idcode_nat) ==\nidmap",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
                "m"
              ],
              "body": null,
              "type": "nat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "{",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(fun x : n = m => path_nat (transport (fun m' : nat => n =n m') x idcode_nat)) ==\nidmap",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
                "m"
              ],
              "body": null,
              "type": "nat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": " "
    },
    {
      "_type": "sentence",
      "contents": "intros []; simpl.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "path_nat idcode_nat = 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n",
