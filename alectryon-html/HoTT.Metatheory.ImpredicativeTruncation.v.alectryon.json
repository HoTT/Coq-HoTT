    {
      "_type": "text",
      "contents": "\n\n(** The universe constraints go away if we assume propositional resizing. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section AssumePropResizing.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{PropResizing}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** If we assume propositions resizing, then we may as well quantify over propositions in the lowest universe [Set] when defining the truncation.  This reduces the number of universe variables.  We also assume that [Set < i], so that the construction lands in universe [i]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition imp_Trm@{i | Set < i} (A : Type@{i}) : Type@{i}\n    := Trm@{i Set} A.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Here we use propositional resizing to resize a arbitrary proposition [P] from an arbitrary universe [j] to universe [Set], so there is no constraint on the universe [j].  In particular, we can take [j = i], which shows that [imp_Trm] is a reflective subuniverse of [Type@{i}], since any two maps into a proposition agree. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition imp_Trm_rec@{i j | Set < i} {A : Type@{i}}\n    {P : Type@{j}} `{IsHProp P} (f : A -> P)\n    : imp_Trm@{i} A -> P\n    := fun ma => (equiv_smalltype@{Set j} P)\n                 (ma (smalltype@{Set j} P) _ ((equiv_smalltype@{Set j} P)^-1 o f)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Similarly, there are no constraints between [i] and [i'] in the next definition, so they could be taken to be equal. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_imp_Trm@{i i' | Set < i, Set < i'} `{Funext}\n    {A : Type@{i}} {A' : Type@{i'}} (f : A -> A')\n    : imp_Trm@{i} A -> imp_Trm@{i'} A'\n    := imp_Trm_rec (trm o f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Note that [imp_Trm_rec] only computes propositionally. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition imp_Trm_rec_beta@{i j | Set < i} {A : Type@{i}}\n    {P : Type@{j}} `{IsHProp P} (f : A -> P)\n    : imp_Trm_rec@{i j} f o trm == f.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "imp_Trm_rec f o trm == f",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "PropResizing"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "IsHProp0"
              ],
              "body": null,
              "type": "IsHProp P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "A -> P"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
