              ],
              "body": null,
              "type": "IsHProp B"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "apply istrunc_forall@{k j k}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** As mentioned above, it eliminates into propositions in universe [j]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Trm_rec@{i j | } {A : Type@{i}}\n  {P : Type@{j}} {p : IsHProp@{j} P} (f : A -> P)\n  : Trm@{i j} A -> P\n  := fun ma => ma P p f.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** This computes definitionally. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Trm_rec_beta@{i j | } {A : Type@{i}}\n  {P : Type@{j}} `{IsHProp P} (f : A -> P)\n  : Trm_rec@{i j} f o trm == f\n  := fun _ => idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Because of the universe constraints, we can't make this into a functor on [Type@{i}].  We have a universe constraint [i' <= j] and [Trm@{i j} A] lands in [max(i,j+1)], which is strictly larger. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_Trm@{i j i' j' | i' <= j, j' < j} `{Funext}\n  {A : Type@{i}} {A' : Type@{i'}} (f : A -> A')\n  : Trm@{i j} A -> Trm@{i' j'} A'\n  := Trm_rec (trm o f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We also record the dependent induction principle.  But it only computes propositionally. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Trm_ind@{i j k | i <= k, j < k} {A : Type@{i}} `{Funext}\n  {P : Trm@{i j} A -> Type@{j}} {p : forall x, IsHProp@{j} (P x)} (f : forall a, P (trm a))\n  : forall x, P x.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall x : Trm A, P x",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Trm A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "forall x : Trm A, IsHProp (P x)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "forall a : A, P (trm a)"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall x : Trm A, P x",
          "hypotheses": [
