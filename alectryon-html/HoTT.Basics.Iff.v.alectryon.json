    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Universe Minimization ToSet.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** * If and only if *)\n\n(** ** Definition *)\n\n(** [iff A B], written [A <-> B], expresses the logical equivalence of [A] and [B] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition iff (A B : Type) := prod (A -> B) (B -> A).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"A <-> B\" := (iff A B) : type_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Basic Properties *)\n\n(** Everything is logically equivalent to itself. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition iff_refl {A} : A <-> A\n  := (idmap , idmap).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** [iff] is a reflexive relation. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance iff_reflexive : Reflexive iff | 1\n  := @iff_refl.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Logical equivalences can be inverted. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition iff_inverse {A B} : (A <-> B) -> (B <-> A)\n  :=  fun f => (snd f , fst f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** [iff] is a symmetric relation. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance symmetric_iff : Symmetric iff | 1\n  := @iff_inverse.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Logical equivalences can be composed. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition iff_compose {A B C} (f : A <-> B) (g : B <-> C) : A <-> C\n  := (fst g o fst f , snd f o snd g).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** [iff] is a transitive relation. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance transitive_iff : Transitive iff | 1\n  := @iff_compose.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Any equivalence can be considered a logical equivalence by discarding everything but the maps. We make this a coercion so that equivalences can be used in place of logical equivalences. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Coercion iff_equiv {A B : Type} (f : A <~> B)\n  : A <-> B := (equiv_fun f, f^-1).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Logical Laws *)\n\n(** One of De Morgan's Laws.  The dual statement about negating a product appears in Decidable.v due to decidability requirements. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition iff_not_sum A B : ~ (A + B) <-> ~ A * ~ B.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "~ (A + B) <-> ~ A * ~ B",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
              "body": null,
              "type": "Type"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "~ (A + B) <-> ~ A * ~ B",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
