[
  [
    {
      "_type": "sentence",
      "contents": "(** * The category of semisimplicial sets *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Types Basics.Trunc.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Morphisms.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Dual FunctorCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import SetCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import SimplicialSets.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Sigma.OnMorphisms Category.Subcategory.Wide.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section semisimplicial_sets.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    (** Quoting David Spivak:\n\n        Consider the subcategory of [\u0394] with the same objects (wide)\n        but only injective morphisms.  If we call that [\u0393] (which is\n        nonstandard), then semi-simplicial sets (also a non-standard\n        term) (sic) are [Fun(\u0393\u1d52\u1d56, Set)]. Define the obvious inclusion\n        [\u0393 -> \u0394], which we will use to make simplicial sets without\n        having to worry about \"degeneracies\". *)\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition semisimplex_category : PreCategory\n      := wide simplex_category\n              (@IsMonomorphism _)\n              _ _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition semisimplicial_inclusion_functor : semisimplex_category -> simplex_category\n      := pr1_mor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition semisimplicial_category (C : PreCategory) : PreCategory\n      := semisimplex_category^op -> C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition semisimplicial_set := semisimplicial_category set_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition semisimplicial_prop := semisimplicial_category prop_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End semisimplicial_sets.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Notation semisimplicial_of obj := (semisimplicial_category (cat_of obj)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
