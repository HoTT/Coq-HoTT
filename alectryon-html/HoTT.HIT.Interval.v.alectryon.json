              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "a = b"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "exact (interval_ind_beta_seg (fun _ => P) _ _ _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
