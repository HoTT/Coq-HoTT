    },
    {
      "_type": "sentence",
      "contents": "Section opposite.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Functors [(C \u2192 D) \u2194 (C\u1d52\u1d56 \u2192 D\u1d52\u1d56)\u1d52\u1d56] *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition opposite_functor (C D : PreCategory) : Functor (C -> D) (C^op -> D^op)^op\n    := Build_Functor\n         (C -> D) ((C^op -> D^op)^op)\n         (fun F => F^op)%functor\n         (fun _ _ T => T^op)%natural_transformation\n         (fun _ _ _ _ _ => idpath)\n         (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Ltac op_t C D :=\n    split;\n    path_functor;\n    repeat (apply path_forall; intro);\n    simpl;\n    destruct_head NaturalTransformation;\n    exact idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** The above functors are isomorphisms *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition opposite_functor_law C D\n  : opposite_functor C D o (opposite_functor C^op D^op)^op = 1\n    /\\ (opposite_functor C^op D^op)^op o opposite_functor C D = 1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(opposite_functor C D o (opposite_functor C^op D^op)^op = 1) *\n((opposite_functor C^op D^op)^op o opposite_functor C D = 1)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
