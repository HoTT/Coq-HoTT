    {
      "_type": "sentence",
      "contents": "Lemma isisomorphism_set_cat_natural_transformation_paths\n      `{fs : Funext} (X : set_cat) C D F G\n      (T1 T2 : morphism set_cat X (Build_HSet (@NaturalTransformation C D F G)))\n      (H : forall x y, T1 x y = T2 x y)\n      `{@IsIsomorphism set_cat _ _ T1}\n: @IsIsomorphism set_cat _ _ T2.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsIsomorphism T2",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "fs"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "set_cat"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "F",
                "G"
              ],
              "body": null,
              "type": "Core.Functor C D"
            },
            {
              "_type": "hypothesis",
              "names": [
                "T1",
                "T2"
              ],
              "body": null,
              "type": "morphism set_cat X (Build_HSet (NaturalTransformation F G))"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "forall (x : X) (y : C), T1 x y = T2 x y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H0"
              ],
              "body": null,
              "type": "IsIsomorphism T1"
            }
          ]
        }
      ]
    },
