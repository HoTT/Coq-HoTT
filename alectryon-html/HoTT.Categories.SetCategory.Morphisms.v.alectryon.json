    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "exists (T1^-1)%morphism;\n  abstract (\n      first [ apply @iso_moveR_Vp\n            | apply @iso_moveR_pV ];\n      repeat first [ intro\n                   | solve [ auto\n                           | symmetry; auto ]\n                   | apply @path_forall\n                   | path_natural_transformation ]\n    ).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section equiv_iso_set_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (** ** Isomorphisms in [set_cat] are equivalent to equivalences. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition isiso_isequiv s d (m : morphism set_cat s d)\n             `{IsEquiv _ _ m}\n  : IsIsomorphism m\n    := Build_IsIsomorphism\n         set_cat s d\n         m m^-1%function\n         (path_forall _ _ (eissect m))\n         (path_forall _ _ (eisretr m)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition isequiv_isiso s d (m : morphism set_cat s d)\n             `{IsIsomorphism _ _ _ m}\n  : IsEquiv m\n    := Build_IsEquiv\n         _ _\n         m m^-1%morphism\n         (ap10 right_inverse)\n         (ap10 left_inverse)\n         (fun _ => path_ishprop _ _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition iso_equiv (s d : set_cat) (m : s <~> d)\n  : s <~=~> d\n    := Build_Isomorphic\n         (@isiso_isequiv s d m _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance isequiv_isiso_isequiv s d\n  : IsEquiv (@iso_equiv s d) | 0.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (iso_equiv s d)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "s",
                "d"
              ],
              "body": null,
              "type": "set_cat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (iso_equiv s d)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "s",
                "d"
              ],
              "body": null,
              "type": "set_cat"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "refine (isequiv_adjointify\n              (@iso_equiv s d)\n              (fun m => Build_Equiv _ _ _ (@isequiv_isiso s d m m))\n              _\n              _);\n    simpl in *;\n    clear;\n    abstract (\n        intros [? ?]; simpl;\n        unfold iso_equiv; simpl;\n        apply ap;\n        apply path_ishprop\n      ).",
      "messages": [],
      "goals": []
