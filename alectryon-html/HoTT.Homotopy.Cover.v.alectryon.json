    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Functoriality of [O_cover] *)\n\n(** Given [X] and [x : O X], any map [f : X -> Y] out of [X] induces a map [O_cover X x -> O_cover Y (O_functor O f x)]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_O_cover@{u v} `{O : ReflectiveSubuniverse} {X Y : Type@{u}}\n  (f : X -> Y) (x : O X) : O_cover@{u} X x -> O_cover@{u} Y (O_functor O f x)\n  := functor_hfiber (f:=to O _) (g:=to O _)\n       (h:=f) (k:=O_functor O f) (to_O_natural O f) x.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_functor_O_cover `{O : ReflectiveSubuniverse}\n  {X Y : Type} (f : X -> Y) `{IsEquiv _ _ f} (x : O X)\n  : O_cover X x <~> O_cover Y (O_functor O f x)\n  := Build_Equiv _ _ (functor_O_cover f x) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** *** Pointed functoriality *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pfunctor_O_pcover `{O : ReflectiveSubuniverse} {X Y : pType}\n  (f : X ->* Y) : O_pcover O X pt ->* O_pcover O Y pt\n  := functor_pfiber (pto_O_natural O f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pequiv_pfunctor_O_pcover `{O : ReflectiveSubuniverse} {X Y : pType}\n  (f : X ->* Y) `{IsEquiv _ _ f} : O_pcover O X pt <~>* O_pcover O Y pt\n  := Build_pEquiv (pfunctor_O_pcover f) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** In the case of truncations, [ptr_natural] gives a better proof of pointedness. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pfunctor_pTr_pcover `{n : trunc_index} {X Y : pType}\n  (f : X ->* Y) : O_pcover (Tr n) X pt ->* O_pcover (Tr n) Y pt\n  := functor_pfiber (ptr_natural n f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pequiv_pfunctor_pTr_pcover `{n : trunc_index}\n  {X Y : pType} (f : X ->* Y) `{IsEquiv _ _ f}\n  : O_pcover (Tr n) X pt <~>* O_pcover (Tr n) Y pt\n  := Build_pEquiv (pfunctor_pTr_pcover f) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n\n(** * Components *)\n\n(** Path components are given by specializing to [O] being set-truncation. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition comp := O_cover (O:=Tr 0).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pcomp := O_pcover (Tr 0).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pfunctor_pcomp {X Y : pType} := @pfunctor_pTr_pcover (-1) X Y.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pequiv_pfunctor_pcomp {X Y : pType}\n  := @pequiv_pfunctor_pTr_pcover (-1) X Y.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** If a property holds at a given point, then it holds for the whole component. This yields equivalences like the following: *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_comp_property `{Univalence} {X : Type} (x : X)\n  (P : X -> Type) `{forall x, IsHProp (P x)} (Px : P x)\n  : comp (sig P) (tr (x; Px)) <~> comp X (tr x).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "comp {x : _ & P x} (tr (x; Px)) <~> comp X (tr x)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x"
              ],
              "body": null,
              "type": "X"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "X -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H0"
              ],
              "body": null,
              "type": "forall x0 : X, IsHProp (P x0)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Px"
              ],
              "body": null,
              "type": "P x"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
