[
  [
    {
      "_type": "sentence",
      "contents": "(** * Unicode notations for comma categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Warnings \"-notation-overridden\".",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import LaxComma.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export LaxComma.Notations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Set some notations for printing *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"'CAT' \u21d3 a\" := (@lax_slice_category_over _ _ _ a _) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"a \u21d3 'CAT'\" := (@lax_coslice_category_over _ _ _ a _) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"x \u21d3 F\" := (lax_coslice_category x F) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"F \u21d3 x\" := (lax_slice_category x F) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"S \u21d3 T\" := (lax_comma_category S T) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** Set the notation for parsing; typeclasses will automatically decide which of the arguments are functors and which are objects, i.e., functors from the terminal category. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"S \u21d3 T\" := (get_LCC S T) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"'CAT' \u21d1 a\" := (@oplax_slice_category_over _ _ _ a _) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"a \u21d1 'CAT'\" := (@oplax_coslice_category_over _ _ _ a _) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"x \u21d1 F\" := (oplax_coslice_category x F) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"F \u21d1 x\" := (oplax_slice_category x F) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"S \u21d1 T\" := (oplax_comma_category S T) (only printing) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** Set the notation for parsing; typeclasses will automatically decide which of the arguments are functors and which are objects, i.e., functors from the terminal category. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"S \u21d1 T\" := (get_OLCC S T) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]