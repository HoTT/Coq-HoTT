    {
      "_type": "text",
      "contents": "\n\n(** * Cyclic groups *)\n\n(** The [n]-th cyclic group is the cokernel of [ab_mul n]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition cyclic (n : nat) : AbGroup\n  := ab_cokernel (ab_mul (A:=abgroup_Z) n).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition cyclic_in (n : nat) : abgroup_Z $-> cyclic n\n  := grp_quotient_map.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": " \n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition ab_mul_cyclic_in (n : nat) (x y : abgroup_Z)\n  : ab_mul y (cyclic_in n x) = cyclic_in n (y * x)%int.",
