    {
      "_type": "text",
      "contents": "\n\n(** ** Construction of product of functors as a functor - [_\u00d7_ : (C \u2192 D) \u00d7 (C \u2192 D') \u2192 (C \u2192 D \u00d7 D')] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section functorial.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D D' : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_morphism_of\n             s d\n             (m : morphism ((C -> D) * (C -> D')) s d)\n  : morphism (_ -> _) (fst s * snd s)%functor (fst d * snd d)%functor\n    := fst_type m * snd_type m.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor_composition_of\n             s d d'\n             (m1 : morphism ((C -> D) * (C -> D')) s d)\n             (m2 : morphism ((C -> D) * (C -> D')) d d')\n  : functor_morphism_of (m2 o m1)\n    = functor_morphism_of m2 o functor_morphism_of m1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "functor_morphism_of (m2 o m1) =\nfunctor_morphism_of m2 o functor_morphism_of m1",
          "hypotheses": [
            {
              "_type": "hypothesis",
