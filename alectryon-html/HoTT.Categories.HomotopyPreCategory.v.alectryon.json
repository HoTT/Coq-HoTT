[
  [
    {
      "_type": "sentence",
      "contents": "(** * Homotopy precategory of types *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics HoTT.Truncations.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope path_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Quoting the HoTT Book:\n\n    Example. There is a precategory whose type of objects is [U] and\n    with [hom(X,Y) : \u2225X \u2192 Y\u2225\u2080], and composition defined by induction\n    on truncation from ordinary composition [(Y \u2192 Z) \u2192 (X \u2192 Y) \u2192 (X \u2192\n    Z)]. We call this the homotopy precategory of types. *)\n\n(** We don't want access to all of the internals of this category at top level. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module HomotopyPreCategoryInternals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section homotopy_precategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation object := Type (only parsing).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation morphism s d := (Trunc 0 (s -> d)) (only parsing).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose s d d' (m : morphism d d') (m' : morphism s d)\n    : morphism s d'.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Trunc 0 (s -> d')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "s"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d'"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "Trunc 0 (d -> d')"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m'"
              ],
              "body": null,
              "type": "Trunc 0 (s -> d)"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Trunc 0 (s -> d')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "s"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d'"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "Trunc 0 (d -> d')"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m'"
              ],
              "body": null,
              "type": "Trunc 0 (s -> d)"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "revert m'; apply Trunc_rec; intro m'.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Trunc 0 (s -> d')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "s"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d'"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "Trunc 0 (d -> d')"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m'"
              ],
              "body": null,
              "type": "s -> d"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "revert m; apply Trunc_rec; intro m.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Trunc 0 (s -> d')",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "s"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d'"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m'"
              ],
              "body": null,
              "type": "s -> d"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "d -> d'"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "apply tr.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "s -> d'",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "s"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "d'"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m'"
              ],
              "body": null,
              "type": "s -> d"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "d -> d'"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "exact (m o m')%core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition identity x : morphism x x\n      := tr idmap.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments compose [s d d'] m m' / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments identity x / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End homotopy_precategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End HomotopyPreCategoryInternals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** The homotopy precategory of types *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition homotopy_precategory : PreCategory.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": []
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": []
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (@Build_PreCategory\n            Type\n            _\n            (@HomotopyPreCategoryInternals.identity)\n            (@HomotopyPreCategoryInternals.compose)\n            _\n            _\n            _\n            _);\n  simpl; intros;\n  repeat match goal with\n           | [ m : Trunc _ _ |- _ ]\n             => revert m;\n               apply Trunc_ind;\n               [ intro;\n                 match goal with\n                   | [ |- IsHSet (?a = ?b :> ?T) ]\n                     => generalize a b; intros;\n                        let H := fresh in\n                        assert (H : forall x y : T, IsHProp (x = y))\n                 end;\n                 typeclasses eauto\n               | intro ]\n         end;\n  simpl;\n  apply ap;\n  exact idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]