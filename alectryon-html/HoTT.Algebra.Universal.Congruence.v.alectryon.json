    },
    {
      "_type": "sentence",
      "contents": "by destruct (path_ishprop C1 D1),\n                (path_ishprop C2 D2),\n                (path_ishprop C3 D3).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "End congruence.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** A homomorphism [f : forall s, A s -> B s] is compatible\n    with a congruence [\u03a6] iff [\u03a6 s x y] implies [f s x = f s y]. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition HomCompatible {\u03c3 : Signature} {A B : Algebra \u03c3}\n  (\u03a6 : forall s, Relation (A s)) `{!IsCongruence A \u03a6}\n  (f : forall s, A s -> B s) `{!IsHomomorphism f}\n  : Type\n  := forall s (x y : A s), \u03a6 s x y -> f s x = f s y.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    }
  ]
]