              "type": "Funext"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
