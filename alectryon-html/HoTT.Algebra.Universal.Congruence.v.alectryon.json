              "_type": "hypothesis",
              "names": [
                "\u03c3"
              ],
              "body": null,
              "type": "Signature"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Algebra \u03c3"
            },
            {
              "_type": "hypothesis",
              "names": [
                "\u03a6"
              ],
              "body": null,
              "type": "forall s : Sort \u03c3, Relation (A s)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "apply (equiv_hprop_allpath _)^-1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall x y : IsCongruence, x = y",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "\u03c3"
              ],
              "body": null,
              "type": "Signature"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Algebra \u03c3"
            },
            {
              "_type": "hypothesis",
              "names": [
                "\u03a6"
              ],
              "body": null,
              "type": "forall s : Sort \u03c3, Relation (A s)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "intros [C1 C2 C3] [D1 D2 D3].",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "{|\n  is_mere_relation_cong := C1;\n  equiv_rel_cong := C2;\n  ops_compatible_cong := C3\n|} =\n{|\n  is_mere_relation_cong := D1;\n  equiv_rel_cong := D2;\n  ops_compatible_cong := D3\n|}",
          "hypotheses": [
            {
              "_type": "hypothesis",
