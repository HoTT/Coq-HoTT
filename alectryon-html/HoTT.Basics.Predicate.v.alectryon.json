[
  [
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Overture Basics.Tactics Basics.Iff Basics.Classes Basics.Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Overture Basics.Tactics Basics.Iff Basics.Classes Basics.Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Universe Minimization ToSet.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** * Predicates on types *)\n\n(** We use the words \"predicate\" and \"(type) family\" interchangably to mean something of type [A -> Type]. *)\n\n(** ** Predicate equality *)\n\n(** Two predicates are considered \"equal\" if they are pointwise logically equivalent: [forall a, P a <-> Q a]. We express this with [relation_pointwise] to ease typeclass search. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_eq {A : Type} := relation_pointwise (fun _ : A => iff).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** It follows from [reflexive_pointwise], [transitive_pointwise] and [symmetric_pointwise] that [pred_eq] is reflexive, transitive and symmetric. *)\n\n(** ** Subsets of a predicate *)\n\n(** A predicate [P] is a \"subset\" of a predicate [Q] if [forall a, P a -> Q a]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset {A : Type} := relation_pointwise (fun (_ : A) => (->)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** *** Predicate Notations *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Declare Scope predicate_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope predicate_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"\u2286\" := pred_subset : predicate_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"\u2194\" := pred_eq     : predicate_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** *** Properties of subsets *)\n\n(** It follows from [reflexive_pointwise] and [transitive_pointwise] that [pred_subset] is reflexive and transitive. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Coercion pred_subset_pred_eq {A : Type} (P Q : A -> Type)\n  : P \u2194 Q -> P \u2286 Q\n  := fun p x => fst (p x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_pred_eq' {A : Type} (P Q : A -> Type)\n  : P \u2194 Q -> Q \u2286 P\n  := fun p x => snd (p x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The subset relation is antisymmetric. Note that this isn't [Antisymmetry] as defined in [Basics.Classes] since we get a [pred_eq] rather than a path. Under being a hprop and univalance, we would get a path. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_antisymm {A : Type} {P Q : A -> Type}\n  : P \u2286 Q -> Q \u2286 P -> P \u2194 Q.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "P \u2286 Q -> Q \u2286 P -> P \u2194 Q",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Q"
              ],
              "body": null,
              "type": "A -> Type"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "P \u2286 Q -> Q \u2286 P -> P \u2194 Q",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Q"
              ],
              "body": null,
              "type": "A -> Type"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "intros p q x; specialize (p x); specialize (q x); by split.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_precomp {A B : Type} {P Q : B -> Type} (f : A -> B)\n  : P \u2286 Q -> (P o f) \u2286 (Q o f)\n  := pointwise_precomp _ f P Q.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_postcomp {A : Type} {P Q : A -> Type}\n  (F : Type -> Type) (f : forall {X Y}, (X -> Y) -> F X -> F Y) (p : P \u2286 Q)\n  : (F o P) \u2286 (F o Q)\n  := fun x => f (p x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_moveL_equiv {A B : Type} {P : B -> Type} {Q : A -> Type}\n  (f : B <~> A)\n  : (P o f^-1) \u2286 Q -> P \u2286 (Q o f)\n  := pointwise_moveL_equiv _ f P Q.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_subset_moveR_equiv {A B : Type} {P : B -> Type} {Q : A -> Type}\n  (f : A <~> B)\n  : P \u2286 (Q o f^-1) -> (P o f) \u2286 Q\n  := pointwise_moveR_equiv _ f P Q.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section OperationsAndIdentities.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Operations on predicates *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context {A : Type}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation Pred := (A -> Type).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and (P Q : Pred) : Pred\n    := fun a => P a /\\ Q a.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_or (P Q : Pred) : Pred\n    := fun a => P a + Q a.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** True and false predicates *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_unit : Pred\n    := fun _ => Unit.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_empty : Pred\n    := fun _ => Empty.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Relationships between predicates *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_empty_subset (P : Pred) : pred_empty \u2286 P\n    := fun _ => Empty_rec _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_unit_subset (P : Pred) : P \u2286 pred_unit\n    := fun _ _ => tt.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_subset_l (P Q : Pred) : pred_and P Q \u2286 P\n    := fun _ => fst.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_subset_r (P Q : Pred) : pred_and P Q \u2286 Q\n    := fun _ => snd.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_is_meet (P Q R : Pred) (p : R \u2286 P) (q : R \u2286 Q)\n    : R \u2286 pred_and P Q\n    := fun a r => ((p a r), (q a r)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_comm' (P Q : Pred)\n    : pred_and P Q \u2286 pred_and Q P\n    := fun a pq => (snd pq, fst pq).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_comm (P Q : Pred)\n    : pred_and P Q \u2194 pred_and Q P\n    := pred_subset_antisymm (pred_and_comm' P Q) (pred_and_comm' Q P).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_or_is_join (P Q R : Pred) (p : P \u2286 R) (q : Q \u2286 R)\n    : pred_or P Q \u2286 R\n    := fun a pq => match pq with\n                 | inl l => p a l\n                 | inr r => q a r end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_or_comm' (P Q : Pred)\n    : pred_or P Q \u2286 pred_or Q P\n    := fun a pq => match pq with\n                 | inl p => inr p\n                 | inr q => inl q end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_or_comm (P Q : Pred)\n    : pred_or P Q \u2194 pred_or Q P\n    := pred_subset_antisymm (pred_or_comm' P Q) (pred_or_comm' Q P).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pred_and_unit_l (P : Pred) : pred_and pred_unit P \u2194 P.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "pred_and pred_unit P \u2194 P",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Pred"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "pred_and pred_unit P \u2194 P",
          "hypotheses": [
