    {
      "_type": "text",
      "contents": "\n\n(** * Free Abelian Groups *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition FactorsThroughFreeAbGroup (S : Type) (F_S : AbGroup)\n  (i : S -> F_S) (A : AbGroup) (g : S -> A) : Type\n  := {f : F_S $-> A & f o i == g}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Universal property of a free abelian group on a set (type). *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Class IsFreeAbGroupOn (S : Type) (F_S : AbGroup) (i : S -> F_S)\n  := contr_isfreeabgroupon :: forall (A : AbGroup) (g : S -> A),\n      Contr (FactorsThroughFreeAbGroup S F_S i A g).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** A abelian group is free if there exists a generating type on which it is a free group (a basis). *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Class IsFreeAbGroup (F_S : AbGroup)\n  := isfreegroup : {S : _ & {i : _ & IsFreeAbGroupOn S F_S i}}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance isfreeabgroup_isfreeabgroupon (S : Type) (F_S : AbGroup) (i : S -> F_S)\n  {H : IsFreeAbGroupOn S F_S i}\n  : IsFreeAbGroup F_S\n  := (S; i; H).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The abelianization of the free group on a set is the free abelian group. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition FreeAbGroup (S : Type) : AbGroup\n  := abel (FreeGroup S).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments FreeAbGroup S : simpl never.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition freeabgroup_in {S : Type} : S -> FreeAbGroup S\n  := abel_unit o freegroup_in.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition FreeAbGroup_rec {S : Type} {A : AbGroup} (f : S -> A)\n  : FreeAbGroup S $-> A\n  := grp_homo_abel_rec (FreeGroup_rec f).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition FreeAbGroup_rec_beta_in {S : Type} {A : AbGroup} (f : S -> A)\n  : FreeAbGroup_rec f o freeabgroup_in == f\n  := fun _ => idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition FreeAbGroup_ind_homotopy {X : Type} {A : AbGroup}\n  {f f' : FreeAbGroup X $-> A}\n  (p : forall x, f (freeabgroup_in x) = f' (freeabgroup_in x))\n  : f $== f'.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "f $== f'",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AbGroup"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f",
                "f'"
              ],
              "body": null,
              "type": "FreeAbGroup X $-> A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "forall x : X, f (freeabgroup_in x) = f' (freeabgroup_in x)"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
