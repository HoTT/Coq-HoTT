[
  [
    {
      "_type": "sentence",
      "contents": "(** * The simplex category \u0394, and the precategory of simplicial sets, [\u0394\u1d52\u1d56 \u2192 set] *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT Require Import Basics Types Spaces.Nat.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core Functor.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import SetCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import ChainCategory FunctorCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Functor.Identity Functor.Composition.Core Functor.Composition.Laws.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We define the precategory \u0394 of simplices, or finite non-empty linear\n    orders *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section simplicial_sets.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    (** We say that the objects of \u0394 are natural numbers, where a\n        number [n] is morally considered as the canonical [n]-simplex,\n        a finite linear order on [n + 1] elements.  By declaring\n        [chain] to be a local coercion from [nat] to [PreCategory], we\n        can rely on on-the-fly eta-expansion to make this moral\n        consideration a reality, telling Coq that it can unify, for\n        example, [nat -> nat -> Type] with [PreCategory -> PreCategory\n        -> Type] by silently inserting [chain]. *)\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Coercion chain : nat >-> PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition simplex_category\n      := @Build_PreCategory\n           nat\n           Functor\n           identity\n           compose\n           associativity\n           left_identity\n           right_identity\n           _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition simplicial_category (C : PreCategory) : PreCategory\n      := simplex_category^op -> C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition simplicial_set := simplicial_category set_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition simplicial_prop := simplicial_category prop_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End simplicial_sets.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Notation simplicial_of obj := (simplicial_category (cat_of obj)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Notation \u0394 := simplex_category.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]