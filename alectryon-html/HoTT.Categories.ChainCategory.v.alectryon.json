      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope nat_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definitions *)\n(** Quoting Wikipedia (http://en.wikipedia.org/wiki/Total_order##Chains):\n\n    While chain is sometimes merely a synonym for totally ordered set,\n    it can also refer to a totally ordered subset of some partially\n    ordered set. The latter definition has a crucial role in Zorn's\n    lemma. *)\n(** We take the convention that a \"chain\" is a totally ordered or\n    linearly ordered set; the corresponding category on that set has,\n    as morphisms, the order relation. *)\n(* N.B. The notation here (including that [[n]] have as objects the\n   set [{0, 1, ..., n}]) was originally suggested by David Spivak.\n   It's possible that we should pick a different or more common\n   terminology. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (** *** [[\u03c9]], the linear order on \u2115 *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition omega : PreCategory\n    := @Build_PreCategory\n         nat\n         leq\n         leq_refl\n         (fun x y z p q => leq_trans q p)\n         (fun _ _ _ _ _ _ _ => path_ishprop _ _)\n         (fun _ _ _ => path_ishprop _ _)\n         (fun _ _ _ => path_ishprop _ _)\n         _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** *** [[n]], a linear order on a finite set with [n + 1] elements *)\n  (** Using [n + 1] elements allows us to agree with the common\n      definition of an [n]-simplex, where a 0-simplex is a point, and\n      a 1-simplex has two end-points, etc. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition chain (n : nat) : PreCategory\n    := { m : omega | m <= n }%category.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** TODO: Possibly generalize this to arbitrary sets with arbitrary\n      (total?) orders on them? *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Module Export ChainCategoryCoreNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Notation \"[ n ]\" := (chain n) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End ChainCategoryCoreNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
