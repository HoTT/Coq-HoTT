[
  [
    {
      "_type": "sentence",
      "contents": "(** * The category \u03c9 of (\u2115, \u2264), and the chain categories [[n]] *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Subcategory.Full.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Sigma.Univalent.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Morphisms Category.Univalent Category.Strict.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics HoTT.Types HoTT.Spaces.Nat.Core.",
