      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition uniformly_continuous_has_modulus {X Y :Type} {usX : UStructure X}\n  {p : X -> Y} {n : nat} (c : is_modulus_of_uniform_continuity n p)\n  : uniformly_continuous p\n  := fun m => (n; c).",
