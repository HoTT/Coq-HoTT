    {
      "_type": "text",
      "contents": "\n\n(** ** [nat]-graded uniform structures *)\n\n(** A uniform structure on a type consists of an equivalence relation for every natural number, each one being stronger than its predecessor. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Class UStructure (us_type : Type) := {\n  us_rel : nat -> Relation us_type;\n  us_reflexive :: forall n : nat, Reflexive (us_rel n);\n  us_symmetric :: forall n : nat, Symmetric (us_rel n);\n  us_transitive :: forall n : nat, Transitive (us_rel n);\n  us_pred : forall (n : nat) (x y : us_type), us_rel n.+1 x y -> us_rel n x y\n}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"u =[ n ] v\" := (us_rel n u v)\n  (at level 70, format \"u  =[ n ]  v\").",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition us_rel_leq {X : Type} {struct : UStructure X}\n  {m n : nat} (hm : m <= n) {u v : X} (h : u =[n] v)\n  : u =[m] v.",
      "messages": [],
      "goals": [
