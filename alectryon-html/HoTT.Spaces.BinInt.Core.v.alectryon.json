    {
      "_type": "sentence",
      "contents": "From HoTT Require Import Basics.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Spaces.Pos.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Universe Minimization ToSet.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** * Binary Integers *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Close Scope trunc_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Close Scope nat_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope positive_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of the Integers *)\n\n(** We define an integer as being a positive number labelled negative, zero or a positive number labelled positive. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Inductive BinInt : Type0 :=\n  | neg : Pos -> BinInt\n  | zero : BinInt\n  | pos : Pos -> BinInt.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments pos p%_pos.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Declare Scope binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Delimit Scope binint_scope with binint.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The integers are a pointed type *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance ispointed_BinInt : IsPointed BinInt := zero.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Properties of constructors *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition neg_inj {z w : Pos} (p : neg z = neg w) : z = w\n  := transport (fun s => z =\n    (match s with neg a => a | zero => w | pos a => w end)) p (idpath z).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pos_inj {z w : Pos} (p : pos z = pos w) : z = w\n  := transport (fun s => z =\n    (match s with neg a => w | zero => w | pos a => a end)) p (idpath z).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition neg_neq_zero {z : Pos} : ~ (neg z = zero)\n  := fun p => transport (fun s =>\n    match s with neg a => z = a| zero => Empty | pos _ => Empty end) p (idpath z).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pos_neq_zero {z : Pos} : ~ (pos z = zero)\n  := fun p => transport (fun s =>\n    match s with pos a => z = a | zero => Empty | neg _ => Empty end) p (idpath z).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition neg_neq_pos {z w : Pos} : ~ (neg z = pos w)\n  := fun p => transport (fun s =>\n    match s with neg a => z = a | zero => Empty | pos _ => Empty end) p (idpath z).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition zero_neq_neg {z : Pos} := @neg_neq_zero z o symmetry _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition zero_neq_pos {z : Pos} := @pos_neq_zero z o symmetry _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pos_neq_neg {z w : Pos} := @neg_neq_pos z w o symmetry _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Conversion with a decimal representation for printing/parsing *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_to_decimal_binint (n : BinInt) : Decimal.int :=\n  match n with\n    | neg m => Decimal.Neg (pos_to_uint m)\n    | zero  => Decimal.Pos Decimal.Nil\n    | pos m => Decimal.Pos (pos_to_uint m)\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_to_number_binint (n : BinInt) : Numeral.int :=\n  Numeral.IntDec (binint_to_decimal_binint n).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint binint_of_decimal_uint (d : Decimal.uint) : BinInt :=\n  match d with\n    | Decimal.Nil => zero\n    | Decimal.D0 l => binint_of_decimal_uint l\n    | Decimal.D1 l => pos (pos_of_uint_acc l 1)\n    | Decimal.D2 l => pos (pos_of_uint_acc l 1~0)\n    | Decimal.D3 l => pos (pos_of_uint_acc l 1~1)\n    | Decimal.D4 l => pos (pos_of_uint_acc l 1~0~0)\n    | Decimal.D5 l => pos (pos_of_uint_acc l 1~0~1)\n    | Decimal.D6 l => pos (pos_of_uint_acc l 1~1~0)\n    | Decimal.D7 l => pos (pos_of_uint_acc l 1~1~1)\n    | Decimal.D8 l => pos (pos_of_uint_acc l 1~0~0~0)\n    | Decimal.D9 l => pos (pos_of_uint_acc l 1~0~0~1)\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_of_decimal_binint (d : Decimal.int) : BinInt :=\n  match d with\n    | Decimal.Pos u => binint_of_decimal_uint u\n    | Decimal.Neg u => let t := binint_of_decimal_uint u in\n        match t with\n          | pos v => neg v\n          | _ => zero\n        end\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_of_number_binint (d:Numeral.int) :=\n  match d with\n  | Numeral.IntDec d => Some (binint_of_decimal_binint d)\n  | Numeral.IntHex _ => None\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Number Notation BinInt binint_of_number_binint binint_to_number_binint : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(* For some reason 0 can be parsed as an integer, but is printed as [zero]. This notation fixes that. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"0\" := zero : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Doubling and variants *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_double x :=\n  match x with\n    | 0 => 0\n    | pos p => pos p~0\n    | neg p => neg p~0\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_succ_double x :=\n  match x with\n    | 0 => 1\n    | pos p => pos p~1\n    | neg p => neg (pos_pred_double p)\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_pred_double x :=\n  match x with\n    | 0 => neg 1%pos\n    | neg p => neg p~1\n    | pos p => pos (pos_pred_double p)\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Subtraction of positive into [BinInt] *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint binint_pos_sub (x y : Pos) {struct y} : BinInt :=\n  match x, y with\n    | p~1, q~1 => binint_double (binint_pos_sub p q)\n    | p~1, q~0 => binint_succ_double (binint_pos_sub p q)\n    | p~1, 1 => pos p~0\n    | p~0, q~1 => binint_pred_double (binint_pos_sub p q)\n    | p~0, q~0 => binint_double (binint_pos_sub p q)\n    | p~0, 1 => pos (pos_pred_double p)\n    | 1, q~1 => neg q~0\n    | 1, q~0 => neg (pos_pred_double q)\n    | 1, 1 => zero\n  end%pos.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Negation *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_negation x :=\n  match x with\n    | zero => zero\n    | pos x => neg x\n    | neg x => pos x\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"- x\" := (binint_negation x) : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Lemma ibnint_negation_negation n : --n = n.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "- - n = n",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n"
              ],
              "body": null,
              "type": "BinInt"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "- - n = n",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "n"
              ],
              "body": null,
              "type": "BinInt"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "by destruct n.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Qed.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Addition *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_add x y :=\n  match x, y with\n    | 0, y => y\n    | x, 0 => x\n    | pos x', pos y' => pos (x' + y')\n    | pos x', neg y' => binint_pos_sub x' y'\n    | neg x', pos y' => binint_pos_sub y' x'\n    | neg x', neg y' => neg (x' + y')\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"+\" := binint_add : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Successor *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_succ x := x + 1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Predecessor *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_pred x := x + neg 1%pos.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Subtraction *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_sub m n := m + -n.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"-\" := binint_sub : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Multiplication *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_mul x y :=\n  match x, y with\n    | 0, _ => 0\n    | _, 0 => 0\n    | pos x', pos y' => pos (x' * y')\n    | pos x', neg y' => neg (x' * y')\n    | neg x', pos y' => neg (x' * y')\n    | neg x', neg y' => pos (x' * y')\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"*\" := binint_mul : binint_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Power function *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_pow x y :=\n  match y with\n    | pos p => pos_iter (binint_mul x) p 1\n    | 0 => 1\n    | neg _ => 0\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Square *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_square x :=\n  match x with\n    | 0 => 0\n    | pos p => pos (pos_square p)\n    | neg p => pos (pos_square p)\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Sign function *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition binint_sgn z :=\n  match z with\n    | 0 => 0\n    | pos p => 1\n    | neg p => neg 1%pos\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(* ** Decidable paths and truncation. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance decpaths_binint : DecidablePaths BinInt.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "DecidablePaths BinInt",
          "hypotheses": []
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "DecidablePaths BinInt",
          "hypotheses": []
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "intros [n | | n] [m | | m].",
      "messages": [],
      "goals": [
