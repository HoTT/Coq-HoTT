[
  [
    {
      "_type": "sentence",
      "contents": "(** * Opposite natural transformations *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Category.Dual Functor.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Import Category.Dual.CategoryDualNotations Functor.Dual.FunctorDualNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core NaturalTransformation.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of [T\u1d52\u1d56] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition opposite\n           C D\n           (F G : Functor C D)\n           (T : NaturalTransformation F G)\n: NaturalTransformation G^op F^op\n  := Build_NaturalTransformation' (G^op) (F^op)\n                                  (components_of T)\n                                  (fun s d => commutes_sym T d s)\n                                  (fun s d => commutes T d s).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"T ^op\" := (opposite T) : natural_transformation_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** [\u1d52\u1d56] is judgmentally involutive *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope natural_transformation_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition opposite_involutive C D (F G : Functor C D) (T : NaturalTransformation F G)\n: (T^op)^op = T\n  := idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export NaturalTransformationDualNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Notation \"T ^op\" := (opposite T) : natural_transformation_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End NaturalTransformationDualNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]