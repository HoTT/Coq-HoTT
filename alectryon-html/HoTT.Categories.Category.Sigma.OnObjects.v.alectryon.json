    {
      "_type": "sentence",
      "contents": "(** * \u2211-categories on objects - a generalization of subcategories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics HoTT.Types.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core Category.Sigma.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Functor.Composition.Core Functor.Identity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Functor.Paths.",
      "messages": [],
      "goals": []
