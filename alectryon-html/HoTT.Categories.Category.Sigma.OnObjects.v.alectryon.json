      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "split; path_functor; trivial.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "transport\n  (fun GO : sig_type Pobj -> sig_type Pobj =>\n   forall s d : sig_type Pobj,\n   sig_type (fun _ : morphism A (pr1_type s) (pr1_type d) => Unit) ->\n   sig_type (fun _ : morphism A (pr1_type (GO s)) (pr1_type (GO d)) => Unit))\n  1\n  (fun (s d : sig_type Pobj)\n     (m : sig_type (fun _ : morphism A (pr1_type s) (pr1_type d) => Unit)) =>\n   (pr1_type m; tt)) =\n(fun s d : sig_type Pobj => idmap)",
          "hypotheses": [
