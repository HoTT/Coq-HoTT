      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation pr1_type := Overture.pr1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope morphism_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section sig_obj.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable A : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable Pobj : A -> Type.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Definition of [sig_obj]-precategory *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sig_obj : PreCategory\n    := @Build_PreCategory\n         (sig_type Pobj)\n         (fun s d => morphism A (pr1_type s) (pr1_type d))\n         (fun x => @identity A (pr1_type x))\n         (fun s d d' m1 m2 => m1 o m2)%morphism\n         (fun _ _ _ _ => associativity A _ _ _ _)\n         (fun _ _ => left_identity A _ _)\n         (fun _ _ => right_identity A _ _)\n         _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** First projection functor *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition pr1_obj : Functor sig_obj A\n    := Build_Functor\n         sig_obj A\n         (@pr1_type _ _)\n         (fun s d m => m)\n         (fun _ _ _ _ _ => idpath)\n         (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sig_obj_as_sig : PreCategory\n    := @sig A Pobj (fun _ _ _ => Unit) _ (fun _ => tt) (fun _ _ _ _ _ _ _ => tt).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sig_functor_obj : Functor sig_obj_as_sig sig_obj\n    := Build_Functor sig_obj_as_sig sig_obj\n                     (fun x => x)\n                     (fun _ _ => @pr1_type _ _)\n                     (fun _ _ _ _ _ => idpath)\n                     (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sig_functor_obj_inv : Functor sig_obj sig_obj_as_sig\n    := Build_Functor sig_obj sig_obj_as_sig\n                     (fun x => x)\n                     (fun _ _ m => exist _ m tt)\n                     (fun _ _ _ _ _ => idpath)\n                     (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Lemma sig_obj_eq `{Funext}\n  : sig_functor_obj o sig_functor_obj_inv = 1\n    /\\ sig_functor_obj_inv o sig_functor_obj = 1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(sig_functor_obj o sig_functor_obj_inv = 1) *\n(sig_functor_obj_inv o sig_functor_obj = 1)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Pobj"
              ],
              "body": null,
              "type": "A -> Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(sig_functor_obj o sig_functor_obj_inv = 1) *\n(sig_functor_obj_inv o sig_functor_obj = 1)",
          "hypotheses": [
            {
              "_type": "hypothesis",
