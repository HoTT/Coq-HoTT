    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We use a slight generalization; we look at a full 1-precategory\n      of the 2-precategory Cat, such that all types of functors are\n      hSets.  It might be possible to prove that this doesn't buy you\n      anything, because it's probably the case that [IsHSet (Functor C\n      C) \u2192 IsStrictCategory C]. *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable P : PreCategory -> Type.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{HF : forall C D, P C -> P D -> IsHSet (Functor C D)}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** There is a precategory of precategories which satisfy the proposition P *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sub_pre_cat : PreCategory\n    := @Build_PreCategory\n         { C : PreCategory | P C }\n         (fun C D => Functor C.1 D.1)\n         (fun C => identity C.1)\n         (fun _ _ _ F G => F o G)\n         (fun _ _ _ _ _ _ _ => associativity _ _ _)\n         (fun _ _ _ => left_identity _)\n         (fun _ _ _ => right_identity _)\n         (fun s d => HF s.2 d.2).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End sub_pre_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments sub_pre_cat {_} P {_}, {_} P _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "#[local] Hint Extern 4 => progress (cbv beta iota) : typeclass_instances.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition strict_cat `{Funext} : PreCategory\n  := sub_pre_cat (fun C => IsStrictCategory C).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(*Definition Cat `{Funext} : PreCategory.\n  refine (@sub_pre_cat _ (fun C => IsCategory C) _).\n  *)\n\n(** ** The initial and terminal categories are initial and terminal objects in cat *)\n"
