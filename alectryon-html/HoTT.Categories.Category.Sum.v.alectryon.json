      "_type": "sentence",
      "contents": "(** * The coproduct of categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export Category.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of [+] for categories *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section internals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sum_morphism (s d : C + D) : Type\n    := match s, d with\n         | inl s, inl d => morphism C s d\n         | inr s, inr d => morphism D s d\n         | _, _ => Empty\n       end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments sum_morphism _ _ / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sum_identity (x : C + D) : sum_morphism x x\n    := match x with\n         | inl x => identity x\n         | inr x => identity x\n       end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments sum_identity _ / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition sum_compose (s d d' : C + D)\n             (m1 : sum_morphism d d') (m2 : sum_morphism s d)\n  : sum_morphism s d'.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "sum_morphism s d'",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "s",
                "d",
                "d'"
              ],
              "body": null,
              "type": "C + D"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m1"
              ],
              "body": null,
              "type": "sum_morphism d d'"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m2"
              ],
              "body": null,
              "type": "sum_morphism s d"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "sum_morphism s d'",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "s",
                "d",
                "d'"
              ],
              "body": null,
              "type": "C + D"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m1"
              ],
              "body": null,
              "type": "sum_morphism d d'"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m2"
              ],
              "body": null,
              "type": "sum_morphism s d"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "case s, d, d'; simpl in *;\n    solve [ case m1\n          | case m2\n          | eapply compose; eassumption ].",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments sum_compose [_ _ _] _ _ / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End internals.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition sum (C D : PreCategory) : PreCategory.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PreCategory",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (@Build_PreCategory\n            (C + D)\n            (sum_morphism C D)\n            (sum_identity C D)\n            (sum_compose C D)\n            _\n            _\n            _\n            _);\n  abstract (\n      repeat (simpl || apply istrunc_S || intros [] || intro);\n      auto with morphism;\n      typeclasses eauto\n    ).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export CategorySumNotations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Infix \"+\" := sum : category_scope.",
