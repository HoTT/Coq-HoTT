      "_type": "sentence",
      "contents": "refine (@Build_PreCategory\n              (forall a : A, P a)\n              (fun s d => forall a : A, morphism (P a) (s a) (d a))\n              (fun x => fun a => identity (x a))\n              (fun s d d' m2 m1 => fun a => m2 a o m1 a)\n              _\n              _\n              _\n              _);\n    abstract (\n        repeat (intro || apply path_forall);\n        auto with morphism\n      ).",
