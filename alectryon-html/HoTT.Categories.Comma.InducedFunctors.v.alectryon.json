      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "Definition slice_category_induced_functor F' a'\n                 (m : morphism D a a')\n                 (T : NaturalTransformation F' F)\n      : Functor (F / a) (F' / a')\n        := comma_category_induced_functor\n             (s := (F, !a))\n             (d := (F', !a'))\n             (T, @slice_category_induced_functor_nt a a' m).",
