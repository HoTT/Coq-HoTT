[
  [
    {
      "_type": "sentence",
      "contents": "(** * Dependent Product; oplax limit of a functor to Cat *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Cat.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Grothendieck.ToCat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import CategoryOfSections.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section dependent_product.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable P : PreCategory -> Type.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (*Context `{forall C, IsHProp (P C)}.*)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{HF : forall C D, P C -> P D -> IsHSet (Functor C D)}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation cat := (@sub_pre_cat _ P HF).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable F : Functor C cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Quoting http://mathoverflow.net/questions/137689/explicit-description-of-the-oplax-limit-of-a-functor-to-cat:\n\n      The oplax limit is the category of sections for the functor from\n      the Grothendieck construction to the base category.\n\n      The strong limit is the category of cartesian sections\n      (every arrow in the base category gets mapped to a cartesian\n      one).\n\n      Notice how this goes along very well with the interpretation as\n      dependent product and as \u2200: The set theoretic product is just\n      the set of sections into the disjoint union.\n\n      Given a strong functor [F : X \u2192 Cat] we denote the Grothendieck\n      construction by [Gr F].\n\n      There is a canonical functor [\u03c0 : Gr F \u2192 X]. Sections of this\n      functor are functors [s : X \u2192 Gr F] such that [s \u2218 \u03c0 = id]. *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition dependent_product : PreCategory\n    := category_of_sections (Grothendieck.ToCat.pr1 F).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End dependent_product.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation Pi := dependent_product.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]