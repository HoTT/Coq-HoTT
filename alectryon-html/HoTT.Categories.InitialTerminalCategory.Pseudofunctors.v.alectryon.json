    },
    {
      "_type": "sentence",
      "contents": "refine (Build_Pseudofunctor\n              one\n              (fun _ => c)\n              (fun _ _ _ => 1%functor)\n              (fun _ _ _ _ _ => reflexivity _)\n              (fun _ => reflexivity _)\n              _\n              _\n              _);\n      simpl;\n      abstract (\n          intros;\n          path_natural_transformation;\n          rewrite ap_const; simpl;\n          reflexivity\n        ).",
      "messages": [],
