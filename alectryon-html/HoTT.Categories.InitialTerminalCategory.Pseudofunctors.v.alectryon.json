    {
      "_type": "text",
      "contents": "\n\n  (** *** Functor from any initial category *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_initial `{Funext} `{@IsInitialCategory zero}\n  : Pseudofunctor zero\n    := Build_Pseudofunctor\n         zero\n         (fun x => initial_category_ind _ x)\n         (fun x _ _ => initial_category_ind _ x)\n         (fun x _ _ _ _ => initial_category_ind _ x)\n         (fun x => initial_category_ind _ x)\n         (fun x => initial_category_ind _ x)\n         (fun x => initial_category_ind _ x)\n         (fun x => initial_category_ind _ x).",
      "messages": [],
      "goals": []
    },
