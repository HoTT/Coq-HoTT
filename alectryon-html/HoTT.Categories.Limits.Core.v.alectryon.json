    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Lemma compose_diagonal_functor x (F : Functor D' D)\n  : diagonal_functor C D x o F = diagonal_functor _ _ x.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "((diagonal_functor C D) _0 x)%object o F =\n((diagonal_functor C D') _0 x)%object",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
