          "_type": "goal",
          "name": null,
          "conclusion": "transport\n  (fun GO : D -> C =>\n   forall s d : D, morphism D s d -> morphism C (GO s) (GO d))\n  1 (fun (s d : D) (_ : morphism D s d) => (X _1 (center Unit))%morphism) =\n(fun (s d : D) (_ : morphism D s d) => 1%morphism)",
