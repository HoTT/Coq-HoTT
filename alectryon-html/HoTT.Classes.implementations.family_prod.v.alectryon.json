    },
    {
      "_type": "sentence",
      "contents": "Require Import\n  HoTT.Utf8Minimal\n  HoTT.Basics.Overture Types.Unit\n  HoTT.Spaces.List.Core.",
      "messages": [],
      "goals": []
    },
