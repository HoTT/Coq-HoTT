    },
    {
      "_type": "text",
      "contents": "\n\n(* Sometimes we end up with a sigma of a one-sided path type that's not eta-expanded, which Coq doesn't seem able to match with the previous instance. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance contr_basedpaths_etashort {X : Type} (x : X) : Contr (sig (@paths X x)) | 100\n  := contr_basedpaths x.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Based path types with the second variable fixed. *)\n\n"
