[
  [
    {
      "_type": "sentence",
      "contents": "(** * Contractibility *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Overture PathGroupoids.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope path_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Naming convention: we consistently abbreviate \"contractible\" as \"contr\".  A theorem about a space [X] being contractible (which will usually be an instance of the typeclass [Contr]) is called [contr_X]. *)\n\n(** Allow ourselves to implicitly generalize over types [A] and [B], and a function [f]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable Variables A B f.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** If a space is contractible, then any two points in it are connected by a path in a canonical way. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition path_contr `{Contr A} (x y : A) : x = y\n  := (contr x)^ @ (contr y).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Any space of paths in a contractible space is contractible. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance contr_paths_contr `{Contr A} (x y : A) : Contr (x = y) | 10000.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Contr (x = y)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Contr0"
              ],
              "body": null,
              "type": "Contr A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x",
                "y"
              ],
              "body": null,
              "type": "A"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Contr (x = y)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Contr0"
              ],
              "body": null,
              "type": "Contr A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x",
                "y"
              ],
              "body": null,
              "type": "A"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "apply (Build_Contr _ (path_contr x y)).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall y0 : x = y, path_contr x y = y0",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Contr0"
              ],
              "body": null,
              "type": "Contr A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x",
                "y"
              ],
              "body": null,
              "type": "A"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "intro r; destruct r; apply concat_Vp.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** It follows that  any two parallel paths in a contractible space are homotopic, which is just the principle UIP. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition path2_contr `{Contr A} {x y : A} (p q : x = y) : p = q\n  := path_contr p q.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Also, the total space of any based path space is contractible.  We define the [contr] fields as separate definitions, so that we can give them [simpl nomatch] annotations. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition path_basedpaths {X : Type} {x y : X} (p : x = y)\n  : (x;1) = (y;p) :> {z:X & x=z}.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(x; 1) = (y; p)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x",
                "y"
              ],
              "body": null,
              "type": "X"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "x = y"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(x; 1) = (y; p)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "X"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "x",
                "y"
              ],
              "body": null,
              "type": "X"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "x = y"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "destruct p; reflexivity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
