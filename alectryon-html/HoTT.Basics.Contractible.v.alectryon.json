      "_type": "sentence",
      "contents": "Definition contr_retract {X Y : Type} `{Contr X} \n           (r : X -> Y) (s : Y -> X) (h : forall y, r (s y) = y)\n  : Contr Y\n  := Build_Contr _ (r (center X)) (fun y => (ap r (contr _)) @ h _).",
      "messages": [],
