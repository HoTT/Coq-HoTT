    {
      "_type": "text",
      "contents": "\n(* We do not need composition to be preserved. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Class Functorish (F : Type -> Type) := {\n  fmap {A B} (f : A -> B) : F A -> F B ;\n  fmap_idmap (A:Type) : fmap (idmap : A -> A) = idmap\n}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments fmap F {FF} {A B} f _ : rename.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments fmap_idmap F {FF A} : rename.",
