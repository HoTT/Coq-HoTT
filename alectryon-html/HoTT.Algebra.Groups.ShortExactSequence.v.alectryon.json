    {
      "_type": "text",
      "contents": "\n\n(** * Complexes of groups *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition grp_cxfib {A B C : Group} {i : A $-> B} {f : B $-> C} (cx : IsComplex i f)\n  : GroupHomomorphism A (grp_kernel f)\n  := grp_kernel_corec _ cx.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition grp_iso_cxfib {A B C : Group} {i : A $-> B} {f : B $-> C}\n           `{IsEmbedding i} (ex : IsExact (Tr (-1)) i f)\n  : GroupIsomorphism A (grp_kernel f)\n  := Build_GroupIsomorphism _ _ (grp_cxfib cx_isexact) (isequiv_cxfib ex).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** This is the same proof as for [equiv_cxfib_beta], but giving the proof is easier than specializing the general result. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Proposition grp_iso_cxfib_beta {A B C : Group} {i : A $-> B} {f : B $-> C}\n            `{IsEmbedding i} (ex : IsExact (Tr (-1)) i f)\n  : i $o (grp_iso_inverse (grp_iso_cxfib ex)) $== subgroup_incl (grp_kernel f).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "i $o grp_iso_inverse (grp_iso_cxfib ex) $== subgroup_incl (grp_kernel f)",
