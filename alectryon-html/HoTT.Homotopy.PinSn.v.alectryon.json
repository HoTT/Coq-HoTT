    {
      "_type": "text",
      "contents": "\n\n(** * We show that the nth homotopy group of the n-sphere is the integers, for n >= 1. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope wc_iso_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope pointed_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The fundamental group of the 1-sphere / circle. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section Pi1S1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Univalence}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Theorem pi1_circle : Pi 1 [Circle, base] \u2245 abgroup_Z.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Pi 1 [Circle, base] \u2245 abgroup_Z",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Pi 1 [Circle, base] \u2245 abgroup_Z",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    (** We give the isomorphism backwards, so we check the operation is preserved coming from the integer side. *)\n    "
    },
    {
      "_type": "sentence",
      "contents": "symmetry.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "abgroup_Z \u2245 Pi 1 [Circle, base]",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "srapply Build_GroupIsomorphism'.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "abgroup_Z <~> Pi 1 [Circle, base]",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            }
          ]
        },
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsSemiGroupPreserving ?f",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Univalence"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "{",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
