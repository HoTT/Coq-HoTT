[
  [
    {
      "_type": "sentence",
      "contents": "(** * Natural Transformations *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** Since there are only notations in [NaturalTransformation.Notations], we can just export those. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export NaturalTransformation.Notations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of natural transformation *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Composition of natural transformations *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Composition.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Dual natural transformations *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Identity natural transformation *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Identity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Natural isomorphisms *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Isomorphisms.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Path space of natural transformation type *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Pointwise natural transformations *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Pointwise.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Sums of natural transformations *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Sum.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** ** Products of natural transformations *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Prod.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Composition.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Dual.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Identity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Isomorphisms.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Pointwise.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Sum.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Include NaturalTransformation.Prod.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n(** We don't want to make UTF-8 notations the default, so we don't export them. *)\n\n(** Since [Composition] is a separate sub-directory, we need to re-create the module structure *)\n(** We want to have the following as subdirectories/modules, not at top level.  Unfortunately, namespacing in Coq is kind-of broken (see, e.g., https://coq.inria.fr/bugs/show_bug.cgi?id=3676), so we don't get the ability to rename subfolders by [Including] into other modules. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Require NaturalTransformation.Composition.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]