    },
    {
      "_type": "sentence",
      "contents": "refine (Build_NaturalTransformation\n              (hom_functor C)\n              (hom_functor D o (F^op, F))\n              (fun (sd : object (C^op * C)) m => (F _1 m)%morphism)\n              _\n           ).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall (s d : (C^op * C)%category) (m : morphism (C^op * C) s d),\n((fun m0 : ((hom_functor C) _0 d)%object => F _1 m0) o (hom_functor C) _1 m)%morphism =\n((hom_functor D o (F^op, F)) _1 m\n o (fun m0 : ((hom_functor C) _0 s)%object => F _1 m0))%morphism",
          "hypotheses": [
            {
              "_type": "hypothesis",
