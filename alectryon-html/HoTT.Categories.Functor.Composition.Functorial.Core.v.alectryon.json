    {
      "_type": "sentence",
      "contents": "(** * Functoriality of functor composition *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core NaturalTransformation.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Functor.Composition.Core NaturalTransformation.Composition.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Prod FunctorCategory.Core NaturalTransformation.Composition.Functorial NaturalTransformation.Composition.Laws ExponentialLaws.Law4.Functors.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import NaturalTransformation.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require ProductLaws.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Construction of the functor [_\u2218_ : (C \u2192 D) \u00d7 (D \u2192 E) \u2192 (C \u2192 E)] and its curried variant *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section functorial_composition.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D E : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope natural_transformation_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose_functor_morphism_of\n             s d (m : morphism (C -> D) s d)\n  : morphism ((D -> E) -> (C -> E))\n             (whiskerR_functor _ s)\n             (whiskerR_functor _ d)\n    := Build_NaturalTransformation\n         (whiskerR_functor E s)\n         (whiskerR_functor E d)\n         (fun x => x oL m)\n         (fun _ _ _ => exchange_whisker _ _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose_functor : object ((C -> D) -> ((D -> E) -> (C -> E))).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "((C -> D) -> (D -> E) -> C -> E)%category",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "E"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "((C -> D) -> (D -> E) -> C -> E)%category",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "E"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "refine (Build_Functor\n              (C -> D) ((D -> E) -> (C -> E))\n              (@whiskerR_functor _ _ _ _)\n              compose_functor_morphism_of\n              _\n              _);\n    abstract (\n        path_natural_transformation;\n        rewrite ?composition_of, ?identity_of;\n        reflexivity\n      ).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose_functor_uncurried\n  : object ((C -> D) * (D -> E) -> (C -> E))\n    := ExponentialLaws.Law4.Functors.functor _ _ _ compose_functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition compose_functor' : object ((D -> E) -> ((C -> D) -> (C -> E)))\n    := ExponentialLaws.Law4.Functors.inverse\n         _ _ _ (compose_functor_uncurried o ProductLaws.Swap.functor _ _)%functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End functorial_composition.",
      "messages": [],
      "goals": []
    },
    {
