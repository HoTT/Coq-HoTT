      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "refine (Build_NaturalTransformation\n              (pointwise F F') (pointwise G F')\n              (fun f : object (D -> C') => (F' o f) oL T)%natural_transformation\n              _).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall (s d : (D -> C')%category) (m : morphism (D -> C') s d),\n(F' o d oL T o (pointwise F F') _1 m)%morphism =\n((pointwise G F') _1 m o (F' o s oL T))%morphism",
          "hypotheses": [
            {
