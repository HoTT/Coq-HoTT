            },
            {
              "_type": "hypothesis",
              "names": [
                "F'"
              ],
              "body": null,
              "type": "Functor C' D'"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "NaturalTransformation (pointwise F F') (pointwise G F')",
          "hypotheses": [
