    {
      "_type": "sentence",
      "contents": "(** * Functors to and from initial and terminal categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core Functor.Paths.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import InitialTerminalCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import NatCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section functors.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** *** Functor to any terminal category *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition to_terminal `{@IsTerminalCategory one Hone Hone'}\n  : Functor C one\n    := Build_Functor\n         C one\n         (fun _ => center _)\n         (fun _ _ _ => center _)\n         (fun _ _ _ _ _ => contr _)\n         (fun _ => contr _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** *** Constant functor from any terminal category *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_terminal `{@IsTerminalCategory one Hone Hone'} (c : C)\n  : Functor one C\n    := Build_Functor\n         one C\n         (fun _ => c)\n         (fun _ _ _ => identity c)\n         (fun _ _ _ _ _ => symmetry _ _ (@identity_identity _ _))\n         (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** *** Functor from any initial category *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_initial `{@IsInitialCategory zero}\n  : Functor zero C\n    := Build_Functor\n         zero C\n         (fun x => initial_category_ind _ x)\n         (fun x _ _ => initial_category_ind _ x)\n         (fun x _ _ _ _ => initial_category_ind _ x)\n         (fun x => initial_category_ind _ x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End functors.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Arguments to_terminal / .",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
