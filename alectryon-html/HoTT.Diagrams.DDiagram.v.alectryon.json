    {
      "_type": "text",
      "contents": "\n\n  (** A dependent diagram is said equifibered if all its fibers are equivalences. *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Class Equifibered {G : Graph} {D : Diagram G} (E : DDiagram D) := {\n    isequifibered i j (g : G i j) (x : D i)\n      :: IsEquiv (@arr _ E (i; x) (j; D _f g x) (g; idpath));\n  }.",
      "messages": [],
