    },
    {
      "_type": "text",
      "contents": "\n\n(** A category is a precategory for which [idtoiso] is an equivalence. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation IsCategory C := (forall s d : object C, IsEquiv (@idtoiso C s d)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation isotoid C s d := (@equiv_inv _ _ (@idtoiso C s d) _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** *** The objects of a category are a 1-type *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance trunc_category `{IsCategory C} : IsTrunc 1 C | 10000.",
      "messages": [],
      "goals": [
