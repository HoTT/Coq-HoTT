    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "refine (isequiv_adjointify\n              (fun (g:C->A) => w o g)\n              (fun (g:C->B) => w^-1 o g)\n              _\n              _);\n    intro;\n    pose (Build_Equiv _ _ w _) as w';\n    change H0 with (@equiv_isequiv _ _ w');\n    change w with (@equiv_fun _ _ w');\n    clearbody w'; clear H0 w;\n    rewrite <- (@eisretr _ _ (@equiv_path A B) (ua A B) w');\n    generalize ((@equiv_inv _ _ (equiv_path A B) (ua A B)) w');\n    intro p;\n    clear w';\n    destruct p;\n    reflexivity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We are ready to prove functional extensionality, starting with the naive non-dependent version. *)\n\n  "
    },
