    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "unfold Univalence_type in *.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (fun (g : C -> A) (x : C) => w (g x))",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "ua"
              ],
              "body": null,
              "type": "forall A0 B0 : Type, IsEquiv (equiv_path A0 B0)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
