    },
    {
      "_type": "sentence",
      "contents": "refine (isequiv_adjointify\n              (fst o pr1) (fun x => ((x, x); idpath))\n              (fun _ => idpath)\n              _);\n      let p := fresh in\n      intros [[? ?] p];\n        simpl in p; destruct p;\n        reflexivity.",
