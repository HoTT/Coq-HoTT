    {
      "_type": "sentence",
      "contents": "Context `{ua : Univalence_type}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Exponentiation preserves equivalences, i.e., if [e] is an equivalence then so is post-composition by [e]. *)\n\n  (* Should this go somewhere else? *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Theorem univalence_isequiv_postcompose `{H0 : IsEquiv A B w} C : IsEquiv (fun (g:C->A) => w o g).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (fun g : C -> A => w o g)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "ua"
              ],
              "body": null,
              "type": "Univalence_type"
            },
            {
              "_type": "hypothesis",
