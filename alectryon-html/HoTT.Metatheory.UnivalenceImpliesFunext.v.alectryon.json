              ],
              "body": null,
              "type": "IsEquiv w"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "Type"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsEquiv (fun g : C -> A => w o g)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "ua"
              ],
              "body": null,
              "type": "Univalence_type"
            },
