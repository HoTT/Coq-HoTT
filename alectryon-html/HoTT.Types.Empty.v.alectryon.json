    {
      "_type": "sentence",
      "contents": "Instance isequiv_empty_rec@{u} `{Funext} (A : Type@{u})\n  : IsEquiv@{Set u} (fun (_ : Unit) => @Empty_rec A) | 0\n  := isequiv_adjointify@{Set u} _\n  (fun _ => tt)\n  (fun f => path_forall@{Set u u} _ _ (fun x => Empty_rec x))\n  (fun x => match x with tt => idpath end).",
      "messages": [],
      "goals": []
    },
