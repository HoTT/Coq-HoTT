    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_empty_rec@{u} `{Funext} (A : Type@{u})\n  : Unit <~> ((Empty -> A) : Type@{u})\n  := (Build_Equiv@{Set u} _ _ (fun (_ : Unit) => @Empty_rec A) _).",
      "messages": [],
