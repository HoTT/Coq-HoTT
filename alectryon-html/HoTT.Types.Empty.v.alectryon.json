    },
    {
      "_type": "sentence",
      "contents": "refine (Build_IsEquiv _ _ _ \n    (Empty_ind (fun _ => T))                (* := equiv_inv *)\n    (fun fals:Empty => match fals with end) (* : f o equiv_inv == idmap *)\n    (fun t:T => match (f t) with end)       (* : equiv_inv o f == idmap *)\n    (_)                                     (* adjointify part *)  ).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall x : T,\nmatch\n  f x as fals return (f (Empty_ind (fun _ : Empty => T) fals) = fals)\nwith\nend =\nap f match f x return (Empty_ind (fun _ : Empty => T) (f x) = x) with\n     end",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "T"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
