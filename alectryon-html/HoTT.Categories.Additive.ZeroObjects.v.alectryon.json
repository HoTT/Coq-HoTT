              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism C X Z"
            },
            {
              "_type": "hypothesis",
              "names": [
                "g"
              ],
              "body": null,
              "type": "morphism C Z Y"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
