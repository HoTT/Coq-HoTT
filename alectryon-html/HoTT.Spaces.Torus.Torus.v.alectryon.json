[
  [
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Overture Basics.Equivalences Cubical.DPath",
      "messages": [],
      "goals": []
    },
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Overture Basics.Equivalences Cubical.DPath\n  Cubical.PathSquare Cubical.DPathSquare Cubical.PathCube Cubical.DPathCube.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** In this file we define the Torus as a HIT generated by two loops and a square between them. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation hr := (sq_refl_h _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation vr := (sq_refl_v _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Export Torus.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Private Inductive Torus :=\n    | tbase.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom loop_a : tbase = tbase.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom loop_b : tbase = tbase.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom surf : PathSquare loop_a loop_a loop_b loop_b.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We define the induction principle for Torus *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition Torus_ind (P : Torus -> Type) (pb : P tbase)\n    (pla : DPath P loop_a pb pb) (plb : DPath P loop_b pb pb)\n    (ps : DPathSquare P surf pla pla plb plb) (x : Torus) : P x\n  := (match x with tbase => fun _ _ _ => pb end) pla plb ps.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We declare propositional computational rules for loop_a and loop_b *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom Torus_ind_beta_loop_a : forall (P : Torus -> Type) (pb : P tbase)\n    (pla : DPath P loop_a pb pb) (plb : DPath P loop_b pb pb)\n    (ps : DPathSquare P surf pla pla plb plb), DPathSquare P hr\n      (apD (Torus_ind P pb pla plb ps) (loop_a)) pla 1%dpath 1%dpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom Torus_ind_beta_loop_b : forall (P : Torus -> Type) (pb : P tbase)\n    (pla : DPath P loop_a pb pb) (plb : DPath P loop_b pb pb)\n    (ps : DPathSquare P surf pla pla plb plb), DPathSquare P hr\n      (apD (Torus_ind P pb pla plb ps) (loop_b)) plb 1%dpath 1%dpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We write out the computation rule for surf even though we will not use it. Instead we currently have an unfinished recursion computation principle, but we don't currently know how to derive it from this *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Axiom Torus_ind_beta_surf : forall (P : Torus -> Type) (pb : P tbase)\n    (pla : DPath P loop_a pb pb) (plb : DPath P loop_b pb pb)\n    (ps : DPathSquare P surf pla pla plb plb),\n      DPathCube P (cu_refl_lr _) (ds_apD (Torus_ind P pb pla plb ps) surf) ps\n        (Torus_ind_beta_loop_a _ _ _ _ _) (Torus_ind_beta_loop_a _ _ _ _ _)\n        (Torus_ind_beta_loop_b _ _ _ _ _) (Torus_ind_beta_loop_b _ _ _ _ _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "End Torus.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We can now define Torus recursion as a special case of Torus induction *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Torus_rec (P : Type) (pb : P) (pla plb : pb = pb)\n  (ps : PathSquare pla pla plb plb) : Torus -> P\n  := Torus_ind _ pb (dp_const pla) (dp_const plb) (ds_const ps).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We can derive the recursion computation rules for Torus_rec *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Lemma Torus_rec_beta_loop_a (P : Type) (pb : P) (pla plb : pb = pb)\n  (ps : PathSquare pla pla plb plb)\n  : PathSquare (ap (Torus_rec P pb pla plb ps) loop_a) pla 1 1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathSquare (ap (Torus_rec P pb pla plb ps) loop_a) pla 1 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pb"
              ],
              "body": null,
              "type": "P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pla",
                "plb"
              ],
              "body": null,
              "type": "pb = pb"
            },
            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathSquare (ap (Torus_rec P pb pla plb ps) loop_a) pla 1 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pb"
              ],
              "body": null,
              "type": "P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pla",
                "plb"
              ],
              "body": null,
              "type": "pb = pb"
            },
            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (sq_GGcc _ (eissect _ _)\n    (ds_const'^-1 (Torus_ind_beta_loop_a _ _ _ _ _))).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "dp_const^-1\n  (apD\n     (Torus_ind (fun _ : Torus => P) pb (dp_const pla) \n        (dp_const plb) (ds_const ps))\n     loop_a) =\nap (Torus_rec P pb pla plb ps) loop_a",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pb"
              ],
              "body": null,
              "type": "P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pla",
                "plb"
              ],
              "body": null,
              "type": "pb = pb"
            },
            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "apply moveR_equiv_V, dp_apD_const.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Lemma Torus_rec_beta_loop_b (P : Type) (pb : P) (pla plb : pb = pb)\n  (ps : PathSquare pla pla plb plb)\n  : PathSquare (ap (Torus_rec P pb pla plb ps) loop_b) plb 1 1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathSquare (ap (Torus_rec P pb pla plb ps) loop_b) plb 1 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
