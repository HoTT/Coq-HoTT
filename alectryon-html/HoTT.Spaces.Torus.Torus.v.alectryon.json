              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathCube (sq_ap (Torus_rec P pb pla plb ps) surf) ps\n  (Torus_rec_beta_loop_a P pb pla plb ps)\n  (Torus_rec_beta_loop_a P pb pla plb ps)\n  (Torus_rec_beta_loop_b P pb pla plb ps)\n  (Torus_rec_beta_loop_b P pb pla plb ps)",
          "hypotheses": [
