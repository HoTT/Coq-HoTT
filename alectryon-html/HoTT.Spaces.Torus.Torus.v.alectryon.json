            },
            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "apply moveR_equiv_V, dp_apD_const.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Defined.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** We ought to be able to prove this from Torus_ind_beta_surf but it is currently too difficult. Therefore we will leave it as admitted where it will simply look like an axiom. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Torus_rec_beta_surf (P : Type) (pb : P) (pla plb : pb = pb)\n  (ps : PathSquare pla pla plb plb)\n  :  PathCube (sq_ap (Torus_rec P pb pla plb ps) surf) ps\n      (Torus_rec_beta_loop_a P pb pla plb ps)\n      (Torus_rec_beta_loop_a P pb pla plb ps)\n      (Torus_rec_beta_loop_b P pb pla plb ps)\n      (Torus_rec_beta_loop_b P pb pla plb ps).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathCube (sq_ap (Torus_rec P pb pla plb ps) surf) ps\n  (Torus_rec_beta_loop_a P pb pla plb ps)\n  (Torus_rec_beta_loop_a P pb pla plb ps)\n  (Torus_rec_beta_loop_b P pb pla plb ps)\n  (Torus_rec_beta_loop_b P pb pla plb ps)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
