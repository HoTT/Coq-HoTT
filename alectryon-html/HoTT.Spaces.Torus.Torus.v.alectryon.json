            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "PathSquare (ap (Torus_rec P pb pla plb ps) loop_b) plb 1 1",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pb"
              ],
