            },
            {
              "_type": "hypothesis",
              "names": [
                "ps"
              ],
              "body": null,
              "type": "PathSquare pla pla plb plb"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "refine (sq_GGcc _ (eissect _ _)\n    (ds_const'^-1 (Torus_ind_beta_loop_b _ _ _ _ _))).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "dp_const^-1\n  (apD\n     (Torus_ind (fun _ : Torus => P) pb (dp_const pla) \n        (dp_const plb) (ds_const ps))\n     loop_b) =\nap (Torus_rec P pb pla plb ps) loop_b",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "P"
              ],
              "body": null,
              "type": "Type"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pb"
              ],
              "body": null,
              "type": "P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "pla",
                "plb"
              ],
              "body": null,
