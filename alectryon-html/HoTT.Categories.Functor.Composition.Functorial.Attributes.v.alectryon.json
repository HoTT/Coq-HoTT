              ],
              "body": null,
              "type": "IsEssentiallySurjective H"
            },
            {
              "_type": "hypothesis",
              "names": [
                "F",
                "G"
              ],
              "body": null,
              "type": "Functor B C"
            },
            {
              "_type": "hypothesis",
