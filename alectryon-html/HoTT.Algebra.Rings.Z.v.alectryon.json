    {
      "_type": "text",
      "contents": "\n\n(** Given a ring element [r], we get a map [Int -> R] sending an integer to that multiple of [r]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition rng_int_mult (R : Ring) := grp_pow_homo : R -> Int -> R.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Multiplying a ring element [r] by an integer [n] is equivalent to first multiplying the unit [1] of the ring by [n], and then multiplying the result by [r].  This is distributivity of right multiplication by [r] over the sum. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition rng_int_mult_dist_r {R : Ring} (r : R) (n : cring_Z)\n  : rng_int_mult R r n = (rng_int_mult R 1 n) * r.",
      "messages": [],
      "goals": [
