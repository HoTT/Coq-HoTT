    {
      "_type": "sentence",
      "contents": "Instance isstrict_oplax_comma_category `{fs : Funext} A B S T HA HB H\n: IsStrictCategory (@oplax_comma_category fs A B S T H)\n  := @isstrict_lax_comma_category fs A B S T HA HB H.",
