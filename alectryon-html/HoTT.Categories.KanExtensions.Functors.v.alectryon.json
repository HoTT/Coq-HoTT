[
  [
    {
      "_type": "sentence",
      "contents": "(** * Kan extensions assemble into functors *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import KanExtensions.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Adjoint.UniversalMorphisms.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import FunctorCategory.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Adjoint.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section kan_extension_functors.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variables C C' D : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable p : object (C -> C').",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Left Kan extension functor *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section lan.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `(has_left_kan_extensions\n              : forall h : object (C -> D),\n                  @IsLeftKanExtensionAlong _ _ _ _ p h (left_kan_extensions h)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition left_kan_extension_functor\n    : Functor (C -> D) (C' -> D)\n      := functor__of__initial_morphism has_left_kan_extensions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition left_kan_extension_adjunction\n    : left_kan_extension_functor -| pullback_along D p\n      := adjunction__of__initial_morphism has_left_kan_extensions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End lan.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (** ** Right Kan extension functor *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section ran.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `(has_right_kan_extensions\n              : forall h : object (C -> D),\n                  @IsRightKanExtensionAlong _ _ _ _ p h (right_kan_extensions h)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition right_kan_extension_functor\n    : Functor (C -> D) (C' -> D)\n      := functor__of__terminal_morphism has_right_kan_extensions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition right_kan_extension_adjunction\n    : pullback_along D p -| right_kan_extension_functor\n      := adjunction__of__terminal_morphism has_right_kan_extensions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End ran.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End kan_extension_functors.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]