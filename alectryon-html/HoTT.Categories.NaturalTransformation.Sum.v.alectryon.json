    {
      "_type": "sentence",
      "contents": "refine (Build_NaturalTransformation\n              (F + F') (G + G')\n              (fun x => match x with\n                          | Basics.Overture.inl c => T c\n                          | Basics.Overture.inr c' => T' c'\n                        end)\n              _).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall (s d : (C + C')%category) (m : morphism (C + C') s d),\n(match\n   d as x\n   return\n     (morphism D (Core.object_of (F + F') x) (Core.object_of (G + G') x))\n with\n | Overture.inl c => T c\n | Overture.inr c' => T' c'\n end o Core.morphism_of (F + F') m)%morphism =\n(Core.morphism_of (G + G') m\n o match\n     s as x\n     return\n       (morphism D (Core.object_of (F + F') x) (Core.object_of (G + G') x))\n   with\n   | Overture.inl c => T c\n   | Overture.inr c' => T' c'\n   end)%morphism",
          "hypotheses": [
