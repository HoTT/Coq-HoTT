    {
      "_type": "sentence",
      "contents": "Section congruence.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context {\u03c3 : Signature} (A : Algebra \u03c3) (\u03a6 : \u2200 s, Relation (A s)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** An operation [f : A s1 \u2192 A s2 \u2192 ... \u2192 A sn \u2192 A t] satisfies\n    [OpCompatible f] iff\n\n<<\n      \u03a6 s1 x1 y1 \u2227 \u03a6 s2 x2 y2 \u2227 ... \u2227 \u03a6 sn xn yn\n>>\n\n    implies\n\n<<\n      \u03a6 t (f x1 x2 ... xn) (f y1 y2 ... yn).\n>>\n*)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition OpCompatible {w : SymbolType \u03c3} (f : Operation A w)\n    : Type\n    := \u2200 (a b : FamilyProd A (dom_symboltype w)),\n       for_all_2_family_prod A A \u03a6 a b ->\n       \u03a6 (cod_symboltype w) (ap_operation f a) (ap_operation f b).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Class OpsCompatible : Type\n    := ops_compatible : \u2200 (u : Symbol \u03c3), OpCompatible u.#A.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance trunc_ops_compatible `{Funext} {n : trunc_index}\n    `{!\u2200 s x y, IsTrunc n (\u03a6 s x y)}\n    : IsTrunc n OpsCompatible.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "IsTrunc n OpsCompatible",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "\u03c3"
              ],
              "body": null,
              "type": "Signature"
            },
            {
              "_type": "hypothesis",
