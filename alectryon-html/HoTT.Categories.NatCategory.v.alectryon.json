    },
    {
      "_type": "text",
      "contents": "\n  (** ** [Fin n] types, or [CardinalityRepresentative] *)\n  (** We use [Empty] for [0] and [Unit] for [1] so that we get nice judgmental behavior.\n      TODO: this should be unified with [Spaces.Finite.Fin].\n   *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Fixpoint CardinalityRepresentative (n : nat) : Type0 :=\n    match n with\n      | 0 => Empty\n      | 1 => Unit\n      | S n' => CardinalityRepresentative n' + Unit\n    end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Coercion CardinalityRepresentative : nat >-> Sortclass.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** [Fin n] is an hSet *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance trunc_cardinality_representative (n : nat)\n  : IsHSet (CardinalityRepresentative n).",
