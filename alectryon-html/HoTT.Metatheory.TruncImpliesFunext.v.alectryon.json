                "b"
              ],
              "body": null,
              "type": "P"
            },
            {
              "_type": "hypothesis",
              "names": [
                "p"
              ],
              "body": null,
              "type": "a = b"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  (* We define this map by factoring it through the type [{ x : P & x = b}], which is a proposition since it is contractible. *)\n  "
    },
