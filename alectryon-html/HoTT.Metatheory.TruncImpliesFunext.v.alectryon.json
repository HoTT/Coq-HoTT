    {
      "_type": "sentence",
      "contents": "Definition finterval_rec_beta (P : Type) (a b : P) (p : a = b)\n    : finterval_rec P a b p (trm true) = a\n    := idpath.",
      "messages": [],
      "goals": []
    },
