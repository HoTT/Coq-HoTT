    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope morphism_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Quoting the HoTT Book: *)\n(** Definition. A _strict category_ is a precategory whose type of\n    objects is a set. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation IsStrictCategory C := (IsHSet (object C)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record StrictCategory :=\n  {\n    precategory_strict :> PreCategory;\n    isstrict_StrictCategory :> IsStrictCategory precategory_strict\n  }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Existing Instance isstrict_StrictCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]