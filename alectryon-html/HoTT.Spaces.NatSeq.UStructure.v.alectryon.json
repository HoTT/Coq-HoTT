    {
      "_type": "sentence",
      "contents": "Definition list_restrict_eq_iff_seq_agree_inductive\n  {A : Type} {n : nat} {s t : nat -> A}\n  : list_restrict s n = list_restrict t n <-> seq_agree_inductive n s t\n  := iff_compose\n      list_restrict_eq_iff_seq_agree_lt\n      seq_agree_lt_iff_seq_agree_inductive.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Continuity *)\n\n(** Following https://martinescardo.github.io/TypeTopology/TypeTopology.CantorSearch.html#920.  *)\n\n(** A uniformly continuous function takes homotopic sequences to outputs that are equivalent with respect to the structure on [Y]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition uniformly_continuous_extensionality\n  {X Y : Type} {usY : UStructure Y} (p : (nat -> X) -> Y) {m : nat}\n  (c : uniformly_continuous p)\n  {u v : nat -> X} (h : u == v)\n  : p u =[m] p v\n  := (c m).2 u v (fun m _ => h m).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Composing a uniformly continuous function with the [cons] operation decreases the modulus by 1. Maybe this can be done with greater generality for the structure on [Y]. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition cons_decreases_modulus {X Y : Type}\n  (p : (nat -> X) -> Y) (n : nat) (b : X)\n  (hSn : is_modulus_of_uniform_continuity n.+1 p)\n  : is_modulus_of_uniform_continuity n (p o seq_cons b).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "is_modulus_of_uniform_continuity n (p o seq_cons b)",
          "hypotheses": [
            {
              "_type": "hypothesis",
