    {
      "_type": "text",
      "contents": "\n\n(** * Propositional truncation as a colimit. *)\n\n(** In this file we give an alternative construction of the propositional truncation using colimits. This can serve as a metatheoretic justification that propositional truncations exist. *)\n\n(** The sequence of increasing joins. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition Join_seq (A : Type) : Sequence.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Sequence",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "Type"
            }
          ]
        }
      ]
    },
