      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Propositional truncation can be defined as the colimit of this sequence. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition PropTrunc A : Type := Colimit (Join_seq A).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The constructor is given by the colimit constructor. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition ptr_in {A} : A -> PropTrunc A := colim (D:=Join_seq A) 0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The sequential colimit of this sequence is the propositional truncation. *)\n\n(** Universal property of propositional truncation. *)\n"
    },
