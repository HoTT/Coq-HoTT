    {
      "_type": "text",
      "contents": "\n\n(** * Theorems about W-types (well-founded trees) *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Inductive W (A : Type) (B : A -> Type) : Type :=\n  w_sup (x : A) : (B x -> W A B) -> W A B.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition w_label {A B} (w : W A B) : A :=\n  match w with\n  | w_sup x y => x\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition w_arg {A B} (w : W A B) : B (w_label w) -> W A B :=\n  match w with\n  | w_sup x y => y\n  end.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition issig_W (A : Type) (B : A -> Type)\n  : _ <~> W A B := ltac:(issig).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Paths *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_path_wtype {A B} (z z' : W A B)\n  : (w_label z;w_arg z) = (w_label z';w_arg z') :> {a : _ & B a -> W A B} <~> z = z'\n  := (equiv_ap' (issig_W A B)^-1%equiv z z')^-1%equiv.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_path_wtype' {A B} (z z' : W A B)\n  : {p : w_label z = w_label z' & w_arg z = w_arg z' o transport B p}\n    <~> z = z'.",
