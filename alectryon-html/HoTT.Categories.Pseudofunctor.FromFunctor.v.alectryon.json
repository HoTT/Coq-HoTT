      "_type": "sentence",
      "contents": "(** * Functors to cat are pseudofunctors *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core NaturalTransformation.Core.",
