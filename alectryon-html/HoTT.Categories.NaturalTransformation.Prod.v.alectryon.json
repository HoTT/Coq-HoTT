    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "let F0 := match goal with |- NaturalTransformation ?F0 ?G0 => constr:(F0) end in\n    let G0 := match goal with |- NaturalTransformation ?F0 ?G0 => constr:(G0) end in\n    refine (Build_NaturalTransformation\n              F0 G0\n              (fun d => @morphism_of _ _ F (_, _) (_, _) (m, @identity D d))\n              _).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall (s0 d0 : D) (m0 : morphism D s0 d0),\n(F _1 (m, 1) o (induced_snd F s) _1 m0)%morphism =\n((induced_snd F d) _1 m0 o F _1 (m, 1))%morphism",
          "hypotheses": [
            {
              "_type": "hypothesis",
