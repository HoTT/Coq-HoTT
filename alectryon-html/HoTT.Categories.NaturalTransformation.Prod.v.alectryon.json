                "d"
              ],
              "body": null,
              "type": "C"
            },
            {
              "_type": "hypothesis",
              "names": [
                "m"
              ],
              "body": null,
              "type": "morphism C s d"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "NaturalTransformation (induced_snd F s) (induced_snd F d)",
          "hypotheses": [
            {
