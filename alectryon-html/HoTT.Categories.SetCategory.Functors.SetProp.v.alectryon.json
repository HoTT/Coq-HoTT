    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition to_prop := Functor C prop_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition to_set := Functor C set_cat.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_prop := Functor prop_cat C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_set := Functor set_cat C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End set_coercions_definitions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Identity Coercion to_prop_id : to_prop >-> Functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Identity Coercion to_set_id : to_set >-> Functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Identity Coercion from_prop_id : from_prop >-> Functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Identity Coercion from_set_id : from_set >-> Functor.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section set_coercions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Functors to [prop_cat] give rise to functors to [set_cat] *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition to_prop2set (F : to_prop C) : to_set C :=\n    Build_Functor C set_cat\n                  (fun x => Build_HSet (F x))\n                  (fun s d m => (F _1 m)%morphism)\n                  (fun s d d' m m' => composition_of F s d d' m m')\n                  (fun x => identity_of F x).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** Functors from [set_cat] give rise to functors to [prop_cat] *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition from_set2prop (F : from_set C) : from_prop C\n    := Build_Functor prop_cat C\n                     (fun x => F (Build_HSet x))\n                     (fun s d m => (F _1 (m : morphism\n                                                set_cat\n                                                (Build_HSet s)\n                                                (Build_HSet d)))%morphism)\n                     (fun s d d' m m' => composition_of F\n                                                        (Build_HSet s)\n                                                        (Build_HSet d)\n                                                        (Build_HSet d')\n                                                        m\n                                                        m')\n                     (fun x => identity_of F (Build_HSet x)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End set_coercions.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]