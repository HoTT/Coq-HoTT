    },
    {
      "_type": "sentence",
      "contents": "Section adjunction_universal.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (** ** [F \u22a3 G] gives an initial object of [(Y / G)] for all [Y : C] *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section initial.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable F : Functor C D.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable G : Functor D C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable A : F -| G.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable Y : C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition initial_morphism__of__adjunction\n    : object (Y / G)\n      := @CommaCategory.Build_object\n           _ D C\n           (! Y) G\n           (center _)\n           (F Y)\n           ((unit A) Y).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition is_initial_morphism__of__adjunction\n    : IsInitialMorphism initial_morphism__of__adjunction\n      := Build_IsInitialMorphism\n           _\n           _\n           _\n           _\n           ((A : AdjunctionUnit _ _).2 _).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End initial.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments initial_morphism__of__adjunction [C D F G] A Y.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments is_initial_morphism__of__adjunction [C D F G] A Y _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** ** [F \u22a3 G] gives a terminal object of [(F / X)] for all [X : D] *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section terminal.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variables C D : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable F : Functor C D.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable G : Functor D C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable A : F -| G.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable X : D.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition terminal_morphism__of__adjunction\n    : object (F / X)\n      := Eval simpl in\n          dual_functor\n            (! X)^op F^op\n            (initial_morphism__of__adjunction A^op X).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition is_terminal_morphism__of__adjunction\n    : IsTerminalMorphism terminal_morphism__of__adjunction\n      := is_initial_morphism__of__adjunction A^op X.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End terminal.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments terminal_morphism__of__adjunction [C D F G] A X.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Global Arguments is_terminal_morphism__of__adjunction [C D F G] A X _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End adjunction_universal.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
