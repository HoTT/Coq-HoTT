    {
      "_type": "sentence",
      "contents": "Section adjunction_from_universal.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  (** ** an initial object of [(Y / G)] for all [Y : C] gives a left adjoint to [G] *)\n  "
