    {
      "_type": "text",
      "contents": "\n\n(** ** Basic Definitions of Spectra *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record Prespectrum :=\n  { deloop :> nat -> pType\n    ; glue : forall n, deloop n ->* loops (deloop (n .+1)) }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Class IsSpectrum (E : Prespectrum) :=\n  is_equiv_glue :: forall n, IsEquiv (glue E n).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_glue (E : Prespectrum) `{IsSpectrum E}\n: forall n, E n <~>* loops (E n.+1)\n  := fun n => Build_pEquiv (glue E n) _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record Spectrum :=\n  { to_prespectrum :> Prespectrum\n    ; to_is_spectrum :: IsSpectrum to_prespectrum }.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Truncations of spectra *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition strunc `{Univalence} (k : trunc_index) (E : Spectrum) : Spectrum.",
      "messages": [],
      "goals": [
        {
