[
  [
    {
      "_type": "sentence",
      "contents": "(** * Laws about product categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics HoTT.Types.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core InitialTerminalCategory.Core InitialTerminalCategory.Functors Category.Prod Functor.Prod Functor.Composition.Core Functor.Identity Functor.Composition.Laws.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation prod_type := Basics.Overture.prod.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation fst_type := Basics.Overture.fst.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation snd_type := Basics.Overture.snd.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Notation pair_type := Basics.Overture.pair.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Swap functor [C \u00d7 D \u2192 D \u00d7 C] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Swap.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor (C D : PreCategory)\n  : Functor (C * D) (D * C)\n    := Build_Functor (C * D) (D * C)\n                     (fun cd => (snd_type cd, fst_type cd)%core)\n                     (fun _ _ m => (snd_type m, fst_type m)%core)\n                     (fun _ _ _ _ _ => idpath)\n                     (fun _ => idpath).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition law (C D : PreCategory)\n  : functor C D o functor D C = 1\n    := idpath.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Swap.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** [A * (B * C) \u2245 (A * B) * C] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Associativity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section associativity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variables A B C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor : Functor (A * (B * C)) ((A * B) * C)\n      := (fst * (fst o snd)) * (snd o snd).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse : Functor ((A * B) * C) (A * (B * C))\n      := (fst o fst) * ((snd o fst) * snd).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition law\n    : functor o inverse = 1\n      /\\ inverse o functor = 1\n      := (idpath, idpath)%core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End associativity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Associativity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Laws about the initial category [0] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsInitialCategory zero}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"0\" := zero : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance is_initial_category__product\n    : IsInitialCategory (C * 0)\n      := fun P c => initial_category_ind P (snd c).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance is_initial_category__product'\n    : IsInitialCategory (0 * C)\n      := fun P c => initial_category_ind P (fst c).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor : Functor (C * 0) 0 := Functors.from_initial _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor' : Functor (0 * C) 0 := Functors.from_initial _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse : Functor 0 (C * 0) := Functors.from_initial _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse' : Functor 0 (0 * C) := Functors.from_initial _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    (** *** [C \u00d7 0 \u2245 0] *)\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition law\n    : functor o inverse = 1\n      /\\ inverse o functor = 1\n      := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    (** *** [0 \u00d7 C \u2245 0] *)\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition law'\n    : functor' o inverse' = 1\n      /\\ inverse' o functor' = 1\n      := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "End law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End Law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Laws about the terminal category [1] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Module Law1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Section law1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsTerminalCategory one}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"1\" := one : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor : Functor (C * 1) C\n      := fst.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor' : Functor (1 * C) C\n      := snd.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse : Functor C (C * 1)\n      := 1 * Functors.to_terminal _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse' : Functor C (1 * C)\n      := Functors.to_terminal _ * 1.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    (** We could throw this in a [repeat match goal with ... end], but\n      we know the order, so we hard-code the order to speed it up by a\n      factor of about 10. *)\n\n    "
    },
    {
      "_type": "sentence",
      "contents": "Local Ltac t_prod :=\n      split;\n      try first [ exact (compose_fst_prod _ _)\n                | exact (compose_snd_prod _ _) ];\n      [];\n      apply Functor.Prod.Universal.path_prod;\n      rewrite <- !Functor.Composition.Laws.associativity by assumption;\n      (rewrite ?compose_fst_prod, ?compose_snd_prod,\n       ?Functor.Composition.Laws.left_identity,\n       ?Functor.Composition.Laws.right_identity\n        by assumption);\n      try (reflexivity || exact (center _)).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    (** *** [C \u00d7 1 \u2245 C] *)\n    "
    },
    {
      "_type": "sentence",
      "contents": "Lemma law1\n    : functor o inverse = 1\n      /\\ inverse o functor = 1.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "prod_type (functor o inverse = 1) (inverse o functor = 1)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "one"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Contr0"
              ],
              "body": null,
              "type": "Contr 1%category"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H0"
              ],
              "body": null,
              "type": "forall s d : 1%category, Contr (morphism 1 s d)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H1"
              ],
              "body": null,
              "type": "IsTerminalCategory 1"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n    "
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "prod_type (functor o inverse = 1) (inverse o functor = 1)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "H"
              ],
              "body": null,
              "type": "Funext"
            },
            {
              "_type": "hypothesis",
              "names": [
                "one"
              ],
              "body": null,
              "type": "PreCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Contr0"
              ],
              "body": null,
              "type": "Contr 1%category"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H0"
              ],
              "body": null,
              "type": "forall s d : 1%category, Contr (morphism 1 s d)"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H1"
              ],
              "body": null,
              "type": "IsTerminalCategory 1"
            },
            {
              "_type": "hypothesis",
              "names": [
                "C"
              ],
              "body": null,
              "type": "PreCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n      "
    },
    {
      "_type": "sentence",
      "contents": "unfold functor, inverse.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "prod_type (fst o (1 * to_terminal C) = 1) (1 * to_terminal C o fst = 1)",
          "hypotheses": [
