    },
    {
      "_type": "text",
      "contents": "\n\n(** Additive functors compose. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition compose_additive_functors {A B C : AdditiveCategory}\n  (G : AdditiveFunctor B C) (F : AdditiveFunctor A B)\n  : AdditiveFunctor A C.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "AdditiveFunctor A C",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "B"
              ],
