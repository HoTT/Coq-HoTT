              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A W X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "napply zero_morphism_left.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Qed.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Negation is compatible with postcomposition. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse_postcompose {A : AdditiveCategory} {X Y W : object A}\n  (a : morphism A Y W) (f : morphism A X Y)\n  : a o (- f) = - (a o f).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "a o - f = - (a o f)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A Y W"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
