    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Additive functors\n\n    A functor between additive categories is additive when its action on\n    each hom-set is a monoid homomorphism for the canonical addition.\n    Such functors automatically preserve zero morphisms and negation. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Record AdditiveFunctor (A B : AdditiveCategory) := {\n  addfunctor :> Functor A B;\n\n  ismonoidpreserving_addfunctor :: forall (X Y : object A),\n    IsMonoidPreserving (@morphism_of _ _ addfunctor X Y);\n}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments addfunctor {A B} F : rename.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments ismonoidpreserving_addfunctor {A B} F X Y : rename.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** The identity functor is additive. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition id_additive_functor (A : AdditiveCategory)\n  : AdditiveFunctor A A.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "AdditiveFunctor A A",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "AdditiveFunctor A A",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "snapply Build_AdditiveFunctor.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "Functor A A",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            }
          ]
        },
        {
          "_type": "goal",
          "name": null,
          "conclusion": "forall X Y : A, IsMonoidPreserving (morphism_of ?addfunctor (d:=Y))",
          "hypotheses": [
