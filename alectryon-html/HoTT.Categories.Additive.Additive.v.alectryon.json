[
  [
    {
      "_type": "sentence",
      "contents": "(** * Additive categories",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n    Semi-additive categories in which morphism addition admits inverses,\n    so that hom-sets are abelian groups and composition is bilinear. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT Require Import Basics.Overture Basics.Tactics.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT.Classes.interfaces Require Import canonical_names abstract_algebra.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT.Categories Require Import Category.Core Functor.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT.Categories.Functor Require Import Identity Composition.Core.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT.Categories.Additive Require Import ZeroObjects SemiAdditive.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "From HoTT.Algebra.AbGroups Require Import AbelianGroup.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope morphism_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** This lets us use \"+\", \"-\" and \"0\" notation for the commutative monoid\n    structure on hom-sets defined in SemiAdditive.v. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope mc_add_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Definition of additive category\n\n    The commutative monoid structure on hom-sets of a semi-additive category\n    is canonical, so an additive category only needs to assume that each\n    morphism has an additive inverse. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Class AdditiveCategory := {\n  additive_semiadditive :: SemiAdditiveCategory;\n\n  additive_inverse :: forall (X Y : object additive_semiadditive),\n    Inverse (morphism additive_semiadditive X Y);\n\n  additive_inverse_l : forall {X Y : object additive_semiadditive}\n    (f : morphism additive_semiadditive X Y),\n    (- f) + f = 0;\n}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Coercion additive_semiadditive : AdditiveCategory >-> SemiAdditiveCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Hom-sets are abelian groups *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Section HomAbGroup.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context {A : AdditiveCategory} (X Y : object A).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** The bundled abelian group of morphisms from [X] to [Y]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition abgroup_hom : AbGroup\n    := Build_AbGroup' (morphism A X Y) _ _ _ additive_inverse_l.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance isabgroup_morphisms : IsAbGroup (morphism A X Y)\n    := @isabgroup_abgroup abgroup_hom.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "End HomAbGroup.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Negation and composition *)\n\n(** A left additive inverse equals the negation. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition hom_moveL_1V {A : AdditiveCategory} {X Y : object A}\n  {f g : morphism A X Y} (H : g + f = 0)\n  : g = - f\n  := grp_moveL_1V (G:=abgroup_hom X Y) H.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Negation is compatible with precomposition. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse_precompose {A : AdditiveCategory} {X Y W : object A}\n  (f : morphism A X Y) (a : morphism A W X)\n  : (- f) o a = - (f o a).",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "- f o a = - (f o a)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A W X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Proof.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "- f o a = - (f o a)",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A W X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "apply hom_moveL_1V.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "- f o a + f o a = 0",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A W X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "lhs_V napply addition_precompose.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "(- f + f) o a = 0",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "A"
              ],
              "body": null,
              "type": "AdditiveCategory"
            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
