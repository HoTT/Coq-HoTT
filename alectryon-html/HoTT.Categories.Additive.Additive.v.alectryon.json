            },
            {
              "_type": "hypothesis",
              "names": [
                "X",
                "Y",
                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A Y W"
            },
            {
              "_type": "hypothesis",
              "names": [
