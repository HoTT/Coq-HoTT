                "W"
              ],
              "body": null,
              "type": "A"
            },
            {
              "_type": "hypothesis",
              "names": [
                "f"
              ],
              "body": null,
              "type": "morphism A X Y"
            },
            {
              "_type": "hypothesis",
              "names": [
                "a"
              ],
              "body": null,
              "type": "morphism A W X"
            }
          ]
        }
      ]
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "lhs napply (ap (fun g => g o a) (additive_inverse_l f)).",
      "messages": [],
