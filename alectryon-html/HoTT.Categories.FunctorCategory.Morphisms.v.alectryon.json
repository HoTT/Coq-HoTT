    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance reflexive_natural_isomorphism `{Funext} C D\n: Reflexive (@NaturalIsomorphism _ C D) | 0\n  := _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Coercion natural_transformation_of_natural_isomorphism `{Funext} C D F G\n         (T : @NaturalIsomorphism _ C D F G)\n: NaturalTransformation F G\n  := T : morphism _ _ _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Infix \"<~=~>\" := NaturalIsomorphism : natural_transformation_scope.",
      "messages": [],
      "goals": []
    },
