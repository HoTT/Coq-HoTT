    {
      "_type": "text",
      "contents": "\n\n(** ** Natural Isomorphisms - isomorphisms in a functor category *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition NaturalIsomorphism `{Funext} (C D : PreCategory) F G :=\n  @Isomorphic (C -> D) F G.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Arguments NaturalIsomorphism {_} [C D] F G / .",
      "messages": [],
      "goals": []
