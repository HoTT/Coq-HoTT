    {
      "_type": "text",
      "contents": "\n\n(** * The law of excluded middle *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Monomorphic Axiom ExcludedMiddle : Type0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Existing Class ExcludedMiddle.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** Mark this axiom as a \"global axiom\", which some of our tactics will automatically handle. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance is_global_axiom_excludedmiddle : IsGlobalAxiom ExcludedMiddle := {}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Axiom LEM : forall `{ExcludedMiddle} (P : Type), IsHProp P -> P + ~P.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition ExcludedMiddle_type := forall (P : Type), IsHProp P -> P + ~P.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** LEM means that all propositions are decidable *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Instance decidable_lem `{ExcludedMiddle} (P : Type) `{IsHProp P} : Decidable P\n  := LEM P _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** Double-negation elimination *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition DNE_type := forall P, IsHProp P -> ~~P -> P.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
