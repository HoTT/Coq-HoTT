[
  [
    {
      "_type": "sentence",
      "contents": "(** * Exponential laws about the initial category *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Core Functor.Core FunctorCategory.Core Functor.Identity.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import InitialTerminalCategory.Core InitialTerminalCategory.Functors InitialTerminalCategory.NaturalTransformations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import HoTT.Basics HoTT.Types.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Set Implicit Arguments.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Generalizable All Variables.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Open Scope functor_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** In this file, we prove that\n\n      - [x\u2070 \u2245 1]\n      - [0\u02e3 \u2245 0] if [x \u2260 0]\n      - [0\u2070 \u2245 1]\n *)\n(** ** x\u2070 \u2245 1 *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsInitialCategory zero}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsTerminalCategory one}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"0\" := zero : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"1\" := one : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "#[export] Instance IsTerminalCategory_functors_from_initial\n  : IsTerminalCategory (0 -> C) := {}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** There is only one functor to the terminal category [1]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor : Functor (0 -> C) 1\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** We have already proven in [InitialTerminalCategory.v] that [0 -> C] is a terminal category, so there is only one functor to it. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse : Functor 1 (0 -> C)\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Since the objects and morphisms in terminal categories are contractible, functors to a terminal category are also contractible, by [trunc_functor]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition law\n  : functor o inverse = 1\n    /\\ inverse o functor = 1\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End law0.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** [0\u02e3 \u2245 0] if [x \u2260 0] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section law0'.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsInitialCategory zero}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsTerminalCategory one}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"0\" := zero : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"1\" := one : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable C : PreCategory.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Variable c : C.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Instance IsInitialCategory_functors_to_initial_from_inhabited\n  : IsInitialCategory (C -> 0)\n    := fun P F => @Functors.to_initial_category_empty C _ _ F P c.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** There is exactly one functor from an initial category, and we proved above that if [C] is inhabited, then [C -> 0] is initial. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor' : Functor (C -> 0) 0\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** There is exactly one functor from the initial category [0]. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse' : Functor 0 (C -> 0)\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** Since objects and morphisms in an initial category are -1-truncated, so are functors to an initial category. *)\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition law'\n  : functor' o inverse' = 1\n    /\\ inverse' o functor' = 1\n    := center _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End law0'.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** ** [0\u2070 \u2245 1] *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Section law00.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{Funext}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsInitialCategory zero}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsInitialCategory zero'}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Context `{IsTerminalCategory one}.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"0\" := zero : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"00\" := zero' : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n  "
    },
    {
      "_type": "sentence",
      "contents": "Local Notation \"1\" := one : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  (** This is just a special case of the first law above. *)\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition functor00 : Functor (0 -> 0) 1\n    := functor _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition inverse00 : Functor 1 (0 -> 0)\n    := inverse _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n  "
    },
    {
      "_type": "sentence",
      "contents": "Definition law00\n  : functor00 o inverse00 = 1\n    /\\ inverse00 o functor00 = 1\n    := law _.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "End law00.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]