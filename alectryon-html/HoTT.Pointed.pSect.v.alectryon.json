    {
      "_type": "text",
      "contents": "\n\n(* The type of pointed sections of a pointed map. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition pSect {A B : pType} (f : A ->* B)\n  := { s : B ->* A & f o* s ==* pmap_idmap }.",
      "messages": [],
      "goals": []
    },
