      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition issig_psect { A B : pType } (f : A ->* B)\n  : { s : B -> A & { p : s pt = pt\n                        & { H : f o s == idmap\n                                & H pt = ap f p @ (point_eq f) } } }\n  <~> pSect f.",
