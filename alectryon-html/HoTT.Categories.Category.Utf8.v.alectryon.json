[
  [
    {
      "_type": "sentence",
      "contents": "(** * Unicode notations for categories *)",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Category.Morphisms Category.Dual Category.Sum Category.Pi.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Warnings \"-notation-overridden\".",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Export Category.Notations.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Local Set Warnings \"notation-overridden\".",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Require Import Basics.Utf8.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"\u2218\" := compose : morphism_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"m \u207b\u00b9\" := (morphism_inverse m) : morphism_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Infix \"\u2245\" := Isomorphic : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"x \u21a0 y\" := (Epimorphism x y).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"x \u21aa y\" := (Monomorphism x y).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n(** It would be nice to put [, format \"C '\u1d52\u1d56'\"] here, but that makes\n    this notation unparseable. *)\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"C '\u1d52\u1d56'\" := (opposite C) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"\u2200  x .. y , P\" := (forall x, .. (forall y, P) ..).",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"\u2200  x .. y , P\" := (forall x, .. (forall y, P) ..) : type_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    },
    {
      "_type": "sentence",
      "contents": "Notation \"\u2200  x .. y , P\" := (pi (fun x => .. (pi (fun y => P)) .. )) : category_scope.",
      "messages": [],
      "goals": []
    },
    {
      "_type": "text",
      "contents": "\n"
    }
  ]
]