    {
      "_type": "text",
      "contents": "\n\n(** A useful lemma to show that two sequences are equivalent. *)\n\n"
    },
    {
      "_type": "sentence",
      "contents": "Definition equiv_sequence (D1 D2 : Sequence)\n  (H0 : (D1 0) <~> (D2 0))\n  (Hn: forall n (e: (D1 n) <~> (D2 n)),\n    {e' : (D1 n.+1) <~> (D2 n.+1) & (D2 _f 1) o e == e' o (D1 _f 1)})\n  : D1 ~d~ D2.",
      "messages": [],
      "goals": [
        {
          "_type": "goal",
          "name": null,
          "conclusion": "D1 ~d~ D2",
          "hypotheses": [
            {
              "_type": "hypothesis",
              "names": [
                "D1"
              ],
              "body": null,
              "type": "Sequence"
            },
            {
              "_type": "hypothesis",
              "names": [
                "D2"
              ],
              "body": null,
              "type": "Sequence"
            },
            {
              "_type": "hypothesis",
              "names": [
                "H0"
              ],
              "body": null,
              "type": "D1 0 <~> D2 0"
            },
            {
              "_type": "hypothesis",
              "names": [
                "Hn"
              ],
              "body": null,
              "type": "forall (n : sequence_graph) (e : D1 n <~> D2 n),\n{e' : D1 n.+1 <~> D2 n.+1 & D2 _f 1 o e == e' o D1 _f 1}"
            }
          ]
        }
      ]
    },
